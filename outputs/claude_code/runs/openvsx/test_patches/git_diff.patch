+- [x] GET /api/{namespace}/{extension}/version-references - paginated version refs, 400 on negative params
+- [x] GET /api/{namespace}/{extension}/{targetPlatform}/version-references - refs for platform
+- [x] GET /api/{namespace}/{extension}/{version}/file/** - file access, 404 if not found
+- [x] GET /api/{namespace}/{extension}/{targetPlatform}/{version}/file/** - file access with platform
+- [x] GET /api/{namespace}/{extension}/reviews - review list, 404 if not found
+- [x] GET /api/-/search - search extensions, 400 on negative size/offset
+- [x] GET /api/-/query - query extensions, 400 on negative params
+- [x] GET /api/v2/-/query - query v2, 400 on invalid includeAllVersions
+- [x] POST /api/-/query - deprecated, redirects to GET
+- [x] POST /api/-/namespace/create - create namespace with token, 400 on missing name
+- [x] POST /api/user/namespace/create - create namespace (auth), 403 if not logged in
+- [x] POST /api/-/publish - publish extension via token (octet-stream)
+- [x] POST /api/user/publish - publish extension (auth), 403 if not logged in
+- [x] POST /api/{namespace}/{extension}/review - post review, 400 on invalid rating
+- [x] POST /api/{namespace}/{extension}/review/delete - delete review
+- [x] GET /api/-/public-key/{publicId} - get public key, 404 if not found
+- [x] GET /api/version - registry version
+
+## UserAPI (server/src/main/java/org/eclipse/openvsx/UserAPI.java)
+- [x] GET /login-providers - available login providers
+- [x] GET /user/auth-error - last auth error, 404 if no error
