+    @Test
+    void signPublisherAgreement_error() throws Exception {
+        var userData = buildUserData("testuser");
+        when(users.findLoggedInUser()).thenReturn(userData);
+        when(eclipse.signPublisherAgreement(userData))
+                .thenThrow(new ErrorResultException("Not available."));
