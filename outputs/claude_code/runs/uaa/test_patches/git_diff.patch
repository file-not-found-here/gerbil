+class ScimUserEndpointsTest {
+
+    @Mock IdentityZoneManager identityZoneManager;
+    @Mock IsSelfCheck isSelfCheck;
+    @Mock ScimUserProvisioning scimUserProvisioning;
+    @Mock IdentityProviderProvisioning identityProviderProvisioning;
+    @Mock ResourceMonitor<ScimUser> scimUserResourceMonitor;
+    @Mock PasswordValidator passwordValidator;
+    @Mock ExpiringCodeStore codeStore;
+    @Mock ApprovalStore approvalStore;
+    @Mock ScimGroupMembershipManager membershipManager;
+    @Mock ScimUserService scimUserService;
+    @Mock ScimUserAliasHandler aliasHandler;
+    @Mock TransactionTemplate transactionTemplate;
+
+    ScimUserEndpoints endpoint;
+    MockMvc mockMvc;
+    ObjectMapper objectMapper = new ObjectMapper();
+
+    @BeforeEach
+    void setUp() {
+        when(identityZoneManager.getCurrentIdentityZoneId()).thenReturn("uaa");
+
+        Map<Class<? extends Exception>, HttpStatus> statuses = new HashMap<>();
+        statuses.put(ScimException.class, HttpStatus.BAD_REQUEST);
+
+        endpoint = new ScimUserEndpoints(
+                identityZoneManager, isSelfCheck, scimUserProvisioning,
+                identityProviderProvisioning, scimUserResourceMonitor, statuses,
+                passwordValidator, codeStore, approvalStore, membershipManager,
+                scimUserService, aliasHandler, transactionTemplate, false, 500);
+
+        mockMvc = MockMvcBuilders.standaloneSetup(endpoint)
+                .setMessageConverters(new MappingJackson2HttpMessageConverter())
+                .build();
+    }
+
+    private ScimUser buildScimUser(String id, String username) {
+        ScimUser user = new ScimUser(id, username, "Test", "User");
+        user.addEmail(username + "@example.com");
+        user.setVersion(0);
+        return user;
+    }
+
+    @Test
+    void getUser_returnsUserById() throws Exception {
+        ScimUser user = buildScimUser("user-123", "testuser");
+        when(scimUserProvisioning.retrieve("user-123", "uaa")).thenReturn(user);
+        when(membershipManager.getGroupsWithMember(anyString(), any(Boolean.class), anyString()))
+                .thenReturn(Collections.emptySet());
+        when(approvalStore.getApprovalsForUser(anyString(), anyString()))
+                .thenReturn(Collections.emptyList());
+
+        mockMvc.perform(get("/Users/{userId}", "user-123"))
+                .andExpect(status().isOk())
+                .andExpect(jsonPath("$.id").value("user-123"))
+                .andExpect(jsonPath("$.userName").value("testuser"));
+    }
+
+    @Test
+    void listUsers_returnsPagedResults() throws Exception {
+        ScimUser user = buildScimUser("user-123", "testuser");
+        when(scimUserProvisioning.retrieveAll("uaa")).thenReturn(List.of(user));
+
+        mockMvc.perform(get("/Users"))
+                .andExpect(status().isOk())
+                .andExpect(jsonPath("$.resources").isArray());
+    }
+
+    @Test
+    void createUser_returnsCreatedUser() throws Exception {
+        ScimUser input = buildScimUser(null, "newuser");
+        input.setPassword("Secret123!");
+        ScimUser created = buildScimUser("new-user-id", "newuser");
+
+        when(identityProviderProvisioning.retrieveActive(anyString())).thenReturn(Collections.emptyList());
+        when(aliasHandler.aliasPropertiesAreValid(any(), any())).thenReturn(true);
+        when(scimUserProvisioning.createUser(any(ScimUser.class), anyString(), anyString())).thenReturn(created);
+        when(membershipManager.getGroupsWithMember(anyString(), any(Boolean.class), anyString()))
+                .thenReturn(Collections.emptySet());
+        when(approvalStore.getApprovalsForUser(anyString(), anyString()))
+                .thenReturn(Collections.emptyList());
+
+        mockMvc.perform(post("/Users")
+                        .contentType(MediaType.APPLICATION_JSON)
+                        .content(objectMapper.writeValueAsString(input)))
+                .andExpect(status().isCreated())
+                .andExpect(jsonPath("$.id").value("new-user-id"));
+    }
+
+    @Test
+    void deleteUser_returnsOk() throws Exception {
+        ScimUser user = buildScimUser("user-123", "testuser");
+        when(scimUserProvisioning.retrieve("user-123", "uaa")).thenReturn(user);
+        when(membershipManager.getGroupsWithMember(anyString(), any(Boolean.class), anyString()))
+                .thenReturn(Collections.emptySet());
+        when(approvalStore.getApprovalsForUser(anyString(), anyString()))
+                .thenReturn(Collections.emptyList());
+
+        mockMvc.perform(delete("/Users/{userId}", "user-123")
+                        .header("If-Match", "0"))
+                .andExpect(status().isOk());
+    }
+}
