@@ -0,0 +1,148 @@
+package org.cloudfoundry.identity.uaa.account;
+
+import com.fasterxml.jackson.databind.ObjectMapper;
+import org.cloudfoundry.identity.uaa.codestore.ExpiringCode;
+import org.cloudfoundry.identity.uaa.codestore.ExpiringCodeStore;
+import org.cloudfoundry.identity.uaa.scim.ScimUser;
+import org.cloudfoundry.identity.uaa.zone.beans.IdentityZoneManager;
+import org.junit.jupiter.api.AfterEach;
+import org.junit.jupiter.api.BeforeEach;
+import org.junit.jupiter.api.Test;
+import org.junit.jupiter.api.extension.ExtendWith;
+import org.mockito.Mock;
+import org.mockito.junit.jupiter.MockitoExtension;
+import org.mockito.junit.jupiter.MockitoSettings;
+import org.mockito.quality.Strictness;
+import org.springframework.http.MediaType;
+import org.springframework.http.converter.StringHttpMessageConverter;
+import org.springframework.http.converter.json.MappingJackson2HttpMessageConverter;
+import org.springframework.security.core.context.SecurityContextHolder;
+import org.springframework.test.web.servlet.MockMvc;
+import org.springframework.test.web.servlet.setup.MockMvcBuilders;
+
+import java.sql.Timestamp;
+
+import static org.mockito.ArgumentMatchers.any;
+import static org.mockito.ArgumentMatchers.anyString;
+import static org.mockito.ArgumentMatchers.eq;
+import static org.mockito.ArgumentMatchers.isNull;
+import static org.mockito.Mockito.when;
+import static org.springframework.test.web.servlet.request.MockMvcRequestBuilders.post;
+import static org.springframework.test.web.servlet.result.MockMvcResultMatchers.jsonPath;
+import static org.springframework.test.web.servlet.result.MockMvcResultMatchers.status;
+
+@ExtendWith(MockitoExtension.class)
+@MockitoSettings(strictness = Strictness.LENIENT)
+class PasswordResetEndpointTest {
+
+    @Mock ResetPasswordService resetPasswordService;
+    @Mock ExpiringCodeStore codeStore;
+    @Mock IdentityZoneManager identityZoneManager;
+
+    PasswordResetEndpoint endpoint;
+    MockMvc mockMvc;
+    ObjectMapper objectMapper = new ObjectMapper();
+
+    @BeforeEach
+    void setUp() {
+        when(identityZoneManager.getCurrentIdentityZoneId()).thenReturn("uaa");
+        endpoint = new PasswordResetEndpoint(resetPasswordService, codeStore, identityZoneManager);
+        mockMvc = MockMvcBuilders.standaloneSetup(endpoint)
+                .setMessageConverters(new StringHttpMessageConverter(), new MappingJackson2HttpMessageConverter())
+                .build();
+    }
+
+    @AfterEach
+    void tearDown() {
+        SecurityContextHolder.clearContext();
+    }
+
+    @Test
+    void passwordResets_withValidEmail_returns201() throws Exception {
+        ExpiringCode code = new ExpiringCode("reset-code-123", new Timestamp(System.currentTimeMillis() + 300000), "{}", null);
+        ForgotPasswordInfo info = new ForgotPasswordInfo("user-1", "user@example.com", code);
+        when(resetPasswordService.forgotPassword(eq("user@example.com"), isNull(), isNull())).thenReturn(info);
+
+        mockMvc.perform(post("/password_resets")
+                        .contentType(MediaType.TEXT_PLAIN)
+                        .content("user@example.com"))
+                .andExpect(status().isCreated())
+                .andExpect(jsonPath("$.user_id").value("user-1"))
+                .andExpect(jsonPath("$.code").value("reset-code-123"));
+    }
+
+    @Test
+    void passwordResets_userNotFound_returns404() throws Exception {
+        when(resetPasswordService.forgotPassword(anyString(), any(), any()))
+                .thenThrow(new NotFoundException());
+
+        mockMvc.perform(post("/password_resets")
+                        .contentType(MediaType.TEXT_PLAIN)
+                        .content("unknown@example.com"))
+                .andExpect(status().isNotFound());
+    }
+
+    @Test
+    void passwordResets_userConflict_returns409() throws Exception {
+        when(resetPasswordService.forgotPassword(anyString(), any(), any()))
+                .thenThrow(new ConflictException("user-conflict-id", "conflict@example.com"));
+
+        mockMvc.perform(post("/password_resets")
+                        .contentType(MediaType.TEXT_PLAIN)
+                        .content("conflict@example.com"))
+                .andExpect(status().isConflict())
+                .andExpect(jsonPath("$.user_id").value("user-conflict-id"));
+    }
+
+    @Test
+    void passwordChange_withoutChangeCode_returns400() throws Exception {
+        LostPasswordChangeRequest request = new LostPasswordChangeRequest();
+        request.setNewPassword("newPassword1");
+
+        mockMvc.perform(post("/password_change")
+                        .contentType(MediaType.APPLICATION_JSON)
+                        .content(objectMapper.writeValueAsString(request)))
+                .andExpect(status().isBadRequest());
+    }
+
+    @Test
+    void passwordChange_withValidCode_returns200() throws Exception {
+        ExpiringCode expiringCode = new ExpiringCode("valid-code", new Timestamp(System.currentTimeMillis() + 300000), "{\"user_id\":\"user-1\"}", null);
+        when(codeStore.retrieveCode(eq("valid-code"), anyString())).thenReturn(expiringCode);
+
+        ScimUser user = new ScimUser("user-1", "testuser", "Test", "User");
+        user.setPrimaryEmail("test@example.com");
+        ResetPasswordService.ResetPasswordResponse resetResponse = new ResetPasswordService.ResetPasswordResponse(user, "/redirect", "client-1");
+        when(resetPasswordService.resetPassword(eq(expiringCode), eq("newPassword1"))).thenReturn(resetResponse);
+
+        ExpiringCode loginCode = new ExpiringCode("login-code-abc", new Timestamp(System.currentTimeMillis() + 300000), "{}", null);
+        when(codeStore.generateCode(anyString(), any(Timestamp.class), anyString(), anyString())).thenReturn(loginCode);
+
+        LostPasswordChangeRequest request = new LostPasswordChangeRequest();
+        request.setChangeCode("valid-code");
+        request.setNewPassword("newPassword1");
+
+        mockMvc.perform(post("/password_change")
+                        .contentType(MediaType.APPLICATION_JSON)
+                        .content(objectMapper.writeValueAsString(request)))
+                .andExpect(status().isOk())
+                .andExpect(jsonPath("$.user_id").value("user-1"))
+                .andExpect(jsonPath("$.username").value("testuser"))
+                .andExpect(jsonPath("$.email").value("test@example.com"))
+                .andExpect(jsonPath("$.code").value("login-code-abc"));
+    }
+
+    @Test
+    void passwordChange_withExpiredCode_returns422() throws Exception {
+        when(codeStore.retrieveCode(eq("expired-code"), anyString())).thenReturn(null);
+
+        LostPasswordChangeRequest request = new LostPasswordChangeRequest();
+        request.setChangeCode("expired-code");
+        request.setNewPassword("newPassword1");
+
+        mockMvc.perform(post("/password_change")
+                        .contentType(MediaType.APPLICATION_JSON)
+                        .content(objectMapper.writeValueAsString(request)))
+                .andExpect(status().isUnprocessableEntity());
+    }
+}
