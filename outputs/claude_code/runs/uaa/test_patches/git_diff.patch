+    @Mock
+    Statement statement;
+
+    HealthzEndpoint endpoint;
+    MockMvc mockMvc;
+
+    @BeforeEach
+    void setUp() {
+        // Use 0 sleep time so shutdown hook doesn't delay tests
+        endpoint = new HealthzEndpoint(0, Runtime.getRuntime(), dataSource);
+        mockMvc = MockMvcBuilders.standaloneSetup(endpoint).build();
+    }
+
+    @Test
+    void getHealthz_whenDatabaseStatusUnknown_returns200WithUnknownMessage() throws Exception {
+        // wasLastConnectionSuccessful starts null, so status is "unknown"
+        mockMvc.perform(get("/healthz"))
+                .andExpect(status().isOk())
+                .andExpect(content().string("UAA running. Database status unknown.\n"));
+    }
+
+    @Test
+    void getHealthz_wildcardPath_returns200() throws Exception {
+        mockMvc.perform(get("/healthz/deep/path"))
+                .andExpect(status().isOk())
+                .andExpect(content().string("UAA running. Database status unknown.\n"));
+    }
+
+    @Test
+    void getHealthz_whenDatabaseConnectionSuccessful_returnsOk() throws Exception {
+        when(dataSource.getConnection()).thenReturn(connection);
+        when(connection.createStatement()).thenReturn(statement);
+        when(statement.execute(anyString())).thenReturn(true);
+
+        // Trigger the scheduled check manually
+        endpoint.isDataSourceConnectionAvailable();
+
+        mockMvc.perform(get("/healthz"))
+                .andExpect(status().isOk())
+                .andExpect(content().string("ok\n"));
+    }
+
+    @Test
+    void getHealthz_whenDatabaseConnectionFailed_returns503() throws Exception {
+        when(dataSource.getConnection()).thenThrow(new RuntimeException("DB unavailable"));
+
+        // Trigger the scheduled check manually
+        endpoint.isDataSourceConnectionAvailable();
+
+        mockMvc.perform(get("/healthz"))
+                .andExpect(status().isServiceUnavailable())
+                .andExpect(content().string("Database Connection failed.\n"));
+    }
+}
