+package org.cloudfoundry.identity.uaa.zone;
+
+import com.fasterxml.jackson.databind.ObjectMapper;
+import org.cloudfoundry.identity.uaa.provider.IdentityProviderProvisioning;
+import org.cloudfoundry.identity.uaa.scim.ScimGroupProvisioning;
+import org.junit.jupiter.api.BeforeEach;
+import org.junit.jupiter.api.Test;
+import org.junit.jupiter.api.extension.ExtendWith;
+import org.mockito.Mock;
+import org.mockito.junit.jupiter.MockitoExtension;
+import org.mockito.junit.jupiter.MockitoSettings;
+import org.mockito.quality.Strictness;
+import org.springframework.context.MessageSource;
+import org.springframework.context.support.StaticMessageSource;
+import org.springframework.http.MediaType;
+import org.springframework.http.converter.json.MappingJackson2HttpMessageConverter;
+import org.springframework.test.web.servlet.MockMvc;
+import org.springframework.test.web.servlet.setup.MockMvcBuilders;
+import org.springframework.validation.beanvalidation.LocalValidatorFactoryBean;
+
+import java.util.Collections;
+import java.util.List;
+
+import static org.mockito.ArgumentMatchers.any;
+import static org.mockito.ArgumentMatchers.anyString;
+import static org.mockito.Mockito.when;
+import static org.springframework.test.web.servlet.request.MockMvcRequestBuilders.delete;
+import static org.springframework.test.web.servlet.request.MockMvcRequestBuilders.get;
+import static org.springframework.test.web.servlet.request.MockMvcRequestBuilders.post;
+import static org.springframework.test.web.servlet.request.MockMvcRequestBuilders.put;
+import static org.springframework.test.web.servlet.result.MockMvcResultMatchers.jsonPath;
+import static org.springframework.test.web.servlet.result.MockMvcResultMatchers.status;
+
+@ExtendWith(MockitoExtension.class)
+@MockitoSettings(strictness = Strictness.LENIENT)
+class IdentityZoneEndpointsTest {
+
+    @Mock IdentityZoneProvisioning zoneDao;
+    @Mock IdentityProviderProvisioning idpDao;
+    @Mock IdentityZoneEndpointClientRegistrationService clientRegistrationService;
+    @Mock ScimGroupProvisioning groupProvisioning;
+    @Mock IdentityZoneValidator validator;
+
+    IdentityZoneEndpoints endpoint;
+    MockMvc mockMvc;
+    ObjectMapper objectMapper = new ObjectMapper();
+
+    @BeforeEach
+    void setUp() {
+        MessageSource messageSource = new StaticMessageSource();
+        endpoint = new IdentityZoneEndpoints(zoneDao, idpDao, clientRegistrationService,
+                groupProvisioning, validator, messageSource);
+        endpoint.setApplicationEventPublisher(event -> {});
+
+        LocalValidatorFactoryBean validatorBean = new LocalValidatorFactoryBean();
+        validatorBean.afterPropertiesSet();
+
+        mockMvc = MockMvcBuilders.standaloneSetup(endpoint)
+                .setMessageConverters(new MappingJackson2HttpMessageConverter())
+                .setValidator(validatorBean)
+                .build();
+    }
+
+    private IdentityZone buildZone(String id, String subdomain, String name) {
+        IdentityZone zone = new IdentityZone();
+        zone.setId(id);
+        zone.setSubdomain(subdomain);
+        zone.setName(name);
+        zone.setConfig(new IdentityZoneConfiguration());
+        return zone;
+    }
+
+    @Test
+    void listZones_returnsAllZones() throws Exception {
+        when(zoneDao.retrieveAll()).thenReturn(List.of(buildZone("zone-1", "zone1", "Zone 1")));
+
+        mockMvc.perform(get("/identity-zones"))
+                .andExpect(status().isOk())
+                .andExpect(jsonPath("$").isArray())
+                .andExpect(jsonPath("$[0].id").value("zone-1"));
+    }
+
+    @Test
+    void getZone_returnsZoneById() throws Exception {
+        IdentityZone zone = buildZone("zone-1", "zone1", "Zone 1");
+        when(zoneDao.retrieveIgnoreActiveFlag("zone-1")).thenReturn(zone);
+
+        mockMvc.perform(get("/identity-zones/{id}", "zone-1"))
+                .andExpect(status().isOk())
+                .andExpect(jsonPath("$.id").value("zone-1"))
+                .andExpect(jsonPath("$.subdomain").value("zone1"));
+    }
+
+    @Test
+    void createZone_returns201WithNewZone() throws Exception {
+        IdentityZone input = buildZone("new-zone", "newzone", "New Zone");
+        IdentityZone created = buildZone("new-zone", "newzone", "New Zone");
+
+        when(validator.validate(any(IdentityZone.class), any(IdentityZoneValidator.Mode.class))).thenReturn(input);
+        when(zoneDao.create(any(IdentityZone.class))).thenReturn(created);
+        when(groupProvisioning.createOrGet(any(), anyString())).thenAnswer(inv -> {
+            org.cloudfoundry.identity.uaa.scim.ScimGroup g = inv.getArgument(0);
+            g.setId(java.util.UUID.randomUUID().toString());
+            return g;
+        });
+
+        mockMvc.perform(post("/identity-zones")
+                        .contentType(MediaType.APPLICATION_JSON)
+                        .content(objectMapper.writeValueAsString(input)))
+                .andExpect(status().isCreated())
+                .andExpect(jsonPath("$.id").value("new-zone"));
+    }
+
+    @Test
+    void updateZone_returnsUpdatedZone() throws Exception {
+        IdentityZone existing = buildZone("zone-1", "zone1", "Zone 1");
+        IdentityZone input = buildZone("zone-1", "zone1", "Zone 1 Updated");
+
+        when(zoneDao.retrieveIgnoreActiveFlag("zone-1")).thenReturn(existing);
+        when(validator.validate(any(IdentityZone.class), any(IdentityZoneValidator.Mode.class))).thenReturn(input);
+        when(zoneDao.update(any(IdentityZone.class))).thenReturn(input);
+
+        mockMvc.perform(put("/identity-zones/{id}", "zone-1")
+                        .contentType(MediaType.APPLICATION_JSON)
+                        .content(objectMapper.writeValueAsString(input)))
+                .andExpect(status().isOk())
+                .andExpect(jsonPath("$.name").value("Zone 1 Updated"));
+    }
+
+    @Test
+    void deleteZone_returnsDeletedZone() throws Exception {
+        IdentityZone zone = buildZone("zone-1", "zone1", "Zone 1");
+        when(zoneDao.retrieveIgnoreActiveFlag("zone-1")).thenReturn(zone);
+        when(idpDao.retrieveAll(false, "zone-1")).thenReturn(Collections.emptyList());
+        when(groupProvisioning.retrieveAll("zone-1")).thenReturn(Collections.emptyList());
+
+        mockMvc.perform(delete("/identity-zones/{id}", "zone-1"))
+                .andExpect(status().isOk())
+                .andExpect(jsonPath("$.id").value("zone-1"));
+    }
+}
