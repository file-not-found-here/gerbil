+        ScimGroup group = buildGroup("grp-1", "readers");
+        when(scimGroupProvisioning.retrieve("grp-1", "uaa")).thenReturn(group);
+        when(scimGroupProvisioning.delete("grp-1", 0, "uaa")).thenReturn(group);
+        when(membershipManager.getMembers("grp-1", false, "uaa")).thenReturn(Collections.emptyList());
+
+        mockMvc.perform(delete("/Groups/{groupId}", "grp-1")
+                        .header("If-Match", "0"))
+                .andExpect(status().isOk())
+                .andExpect(jsonPath("$.id").value("grp-1"));
+    }
+}
