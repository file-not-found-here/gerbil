+package com.netflix.spinnaker.fiat.controllers
+
+import com.fasterxml.jackson.databind.ObjectMapper
+import com.netflix.spinnaker.fiat.model.UserPermission
+import com.netflix.spinnaker.fiat.model.resources.Role
+import com.netflix.spinnaker.fiat.permissions.PermissionsRepository
+import com.netflix.spinnaker.fiat.permissions.PermissionsResolver
+import com.netflix.spinnaker.fiat.roles.UserRolesSyncer
+import org.springframework.http.MediaType
+import org.springframework.test.web.servlet.MockMvc
+import org.springframework.test.web.servlet.setup.MockMvcBuilders
+import spock.lang.Specification
+import spock.lang.Subject
+
+import static org.springframework.test.web.servlet.request.MockMvcRequestBuilders.*
+import static org.springframework.test.web.servlet.result.MockMvcResultMatchers.*
+
+class RolesControllerSpec extends Specification {
+
+  PermissionsResolver permissionsResolver = Mock()
+  PermissionsRepository permissionsRepository = Mock()
+  UserRolesSyncer syncer = Mock()
+  ObjectMapper objectMapper = new ObjectMapper()
+  MockMvc mockMvc
+
+  @Subject
+  RolesController controller
+
+  void setup() {
+    controller = new RolesController()
+    controller.permissionsResolver = permissionsResolver
+    controller.permissionsRepository = permissionsRepository
+    controller.syncer = syncer
+
+    mockMvc = MockMvcBuilders.standaloneSetup(controller)
+      .setControllerAdvice(new FiatTestExceptionHandler())
+      .build()
+  }
+
+  def makeUserPermission(String userId) {
+    def perm = new UserPermission()
+    perm.id = userId
+    return perm
+  }
+
+  def "POST /roles/{userId} resolves and stores user permissions"() {
+    given:
+    def perm = makeUserPermission("testuser")
+    permissionsResolver.resolve("testuser") >> perm
+
+    when:
+    def result = mockMvc.perform(post("/roles/testuser"))
+
+    then:
+    result.andExpect(status().isOk())
+    1 * permissionsRepository.put(perm)
+  }
+
+  def "POST /roles/{userId} handles user with roles in permission"() {
+    given:
+    def role = new Role()
+    role.name = "developer"
+    def perm = makeUserPermission("testuser")
+    perm.roles = [role] as Set
+    permissionsResolver.resolve("testuser") >> perm
+
+    when:
+    def result = mockMvc.perform(post("/roles/testuser"))
+
+    then:
+    result.andExpect(status().isOk())
+    1 * permissionsRepository.put(perm)
+  }
+
+  def "PUT /roles/{userId} stores user permissions with provided external roles"() {
+    given:
+    def externalRoles = ["developer", "operator"]
+    def perm = makeUserPermission("testuser")
+    permissionsResolver.resolveAndMerge(_) >> perm
+
+    when:
+    def result = mockMvc.perform(
+      put("/roles/testuser")
+        .contentType(MediaType.APPLICATION_JSON)
+        .content(objectMapper.writeValueAsString(externalRoles))
+    )
+
+    then:
+    result.andExpect(status().isOk())
+    1 * permissionsRepository.put(perm)
+  }
+
+  def "PUT /roles/{userId} with empty roles list removes all roles"() {
+    given:
+    def externalRoles = []
+    def perm = makeUserPermission("testuser")
+    permissionsResolver.resolveAndMerge(_) >> perm
+
+    when:
+    def result = mockMvc.perform(
+      put("/roles/testuser")
+        .contentType(MediaType.APPLICATION_JSON)
+        .content(objectMapper.writeValueAsString(externalRoles))
+    )
+
+    then:
+    result.andExpect(status().isOk())
+  }
+
+  def "DELETE /roles/{userId} removes user permissions"() {
+    when:
+    def result = mockMvc.perform(delete("/roles/testuser"))
+
+    then:
+    result.andExpect(status().isOk())
+    1 * permissionsRepository.remove("testuser")
+  }
+
+  def "POST /roles/sync syncs all users and returns count"() {
+    given:
+    syncer.syncAndReturn(null) >> 3
+
+    expect:
+    mockMvc.perform(
+      post("/roles/sync")
+    ).andExpect(status().isOk())
+      .andExpect(content().string("3"))
+  }
+
+  def "POST /roles/sync returns 503 when no users synced"() {
+    given:
+    syncer.syncAndReturn(null) >> 0
+
+    expect:
+    mockMvc.perform(
+      post("/roles/sync")
+    ).andExpect(status().isServiceUnavailable())
+  }
+
+  def "POST /roles/sync with specific roles syncs only those roles"() {
+    given:
+    def roles = ["developer", "operator"]
+    syncer.syncAndReturn(roles) >> 2
+
+    expect:
+    mockMvc.perform(
+      post("/roles/sync")
+        .contentType(MediaType.APPLICATION_JSON)
+        .content(objectMapper.writeValueAsString(roles))
+    ).andExpect(status().isOk())
+      .andExpect(content().string("2"))
+  }
+
