+package com.netflix.spinnaker.fiat.controllers
+
+import com.fasterxml.jackson.databind.ObjectMapper
+import com.netflix.spectator.api.Counter
+import com.netflix.spectator.api.Id
+import com.netflix.spectator.api.Registry
+import com.netflix.spinnaker.fiat.config.FiatServerConfigurationProperties
+import com.netflix.spinnaker.fiat.model.Authorization
+import com.netflix.spinnaker.fiat.model.UserPermission
+import com.netflix.spinnaker.fiat.model.resources.Account
+import com.netflix.spinnaker.fiat.model.resources.Application
+import com.netflix.spinnaker.fiat.model.resources.Permissions
+import com.netflix.spinnaker.fiat.model.resources.Role
+import com.netflix.spinnaker.fiat.model.resources.ServiceAccount
+import com.netflix.spinnaker.fiat.permissions.PermissionsRepository
+import com.netflix.spinnaker.fiat.permissions.PermissionsResolver
+import com.netflix.spinnaker.fiat.providers.ResourcePermissionProvider
+import org.springframework.http.MediaType
+import org.springframework.test.web.servlet.MockMvc
+import org.springframework.test.web.servlet.setup.MockMvcBuilders
+import spock.lang.Specification
+import spock.lang.Subject
+
+import static org.springframework.test.web.servlet.request.MockMvcRequestBuilders.*
+import static org.springframework.test.web.servlet.result.MockMvcResultMatchers.*
+
+class AuthorizeControllerSpec extends Specification {
+
+  Registry registry = Mock()
+  Id metricId = Mock()
+  Counter counter = Mock()
+  PermissionsRepository permissionsRepository = Mock()
+  PermissionsResolver permissionsResolver = Mock()
+  FiatServerConfigurationProperties configProps = new FiatServerConfigurationProperties()
+  ResourcePermissionProvider<Application> applicationResourcePermissionProvider = Mock()
+  ObjectMapper objectMapper = new ObjectMapper()
+  MockMvc mockMvc
+
+  @Subject
+  AuthorizeController controller
+
+  void setup() {
+    registry.createId("fiat.getUserPermission") >> metricId
+    metricId.withTag(_, _) >> metricId
+    registry.counter(_) >> counter
+
+    controller = new AuthorizeController(
+      registry,
+      permissionsRepository,
+      permissionsResolver,
+      configProps,
+      applicationResourcePermissionProvider,
+      [new Application()],
+      objectMapper
+    )
+    mockMvc = MockMvcBuilders.standaloneSetup(controller)
+      .setControllerAdvice(new FiatTestExceptionHandler())
+      .build()
+  }
+
+  def makeUserPermission(String userId) {
+    def perm = new UserPermission()
+    perm.id = userId
+    return perm
+  }
+
+  def makeUserPermissionWithAccount(String userId, String accountName) {
+    def account = new Account()
+    account.name = accountName
+    def perm = makeUserPermission(userId)
+    perm.accounts = [account] as Set
+    return perm
+  }
+
+  def makeUserPermissionWithApplication(String userId, String appName, Set<Authorization> auths = [Authorization.READ] as Set) {
+    def app = new Application()
+    app.name = appName
+    def perm = makeUserPermission(userId)
+    perm.applications = [app] as Set
+    return perm
+  }
+
+  def makeUserPermissionWithRole(String userId, String roleName) {
+    def role = new Role()
+    role.name = roleName
+    def perm = makeUserPermission(userId)
+    perm.roles = [role] as Set
+    return perm
+  }
+
+  def "GET /authorize returns 405 when getAllEnabled is false (default)"() {
+    expect:
+    mockMvc.perform(get("/authorize"))
+      .andExpect(status().isMethodNotAllowed())
+  }
+
+  def "GET /authorize returns all user permissions when getAllEnabled is true"() {
+    given:
+    configProps.getAllEnabled = true
+    def perm = makeUserPermission("testuser")
+    permissionsRepository.getAllById() >> ["testuser": perm]
+    permissionsRepository.get("testuser") >> Optional.of(perm)
+
+    expect:
+    mockMvc.perform(get("/authorize"))
+      .andExpect(status().isOk())
+      .andExpect(content().contentTypeCompatibleWith(MediaType.APPLICATION_JSON))
+  }
+
+  def "GET /authorize/{userId} returns user permission view"() {
+    given:
+    def perm = makeUserPermission("testuser")
+    permissionsRepository.get("testuser") >> Optional.of(perm)
+
+    expect:
+    mockMvc.perform(get("/authorize/testuser"))
+      .andExpect(status().isOk())
+      .andExpect(jsonPath('$.name').value("testuser"))
+  }
+
+  def "GET /authorize/{userId} returns 404 when user not found"() {
+    given:
+    permissionsRepository.get("noexist") >> Optional.empty()
+
+    expect:
+    mockMvc.perform(get("/authorize/noexist"))
+      .andExpect(status().isNotFound())
+  }
+
+  def "GET /authorize/{userId}/accounts returns user accounts"() {
+    given:
+    def perm = makeUserPermissionWithAccount("testuser", "prod-account")
+    permissionsRepository.get("testuser") >> Optional.of(perm)
+
+    expect:
+    mockMvc.perform(get("/authorize/testuser/accounts"))
+      .andExpect(status().isOk())
+      .andExpect(jsonPath('$.length()').value(1))
+  }
+
+  def "GET /authorize/{userId}/accounts/{accountName} returns specific account"() {
+    given:
+    def perm = makeUserPermissionWithAccount("testuser", "prod-account")
+    permissionsRepository.get("testuser") >> Optional.of(perm)
+
+    expect:
+    mockMvc.perform(get("/authorize/testuser/accounts/prod-account"))
+      .andExpect(status().isOk())
+      .andExpect(jsonPath('$.name').value("prod-account"))
+  }
+
+  def "GET /authorize/{userId}/accounts/{accountName} returns 404 for unknown account"() {
+    given:
+    def perm = makeUserPermissionWithAccount("testuser", "other-account")
+    permissionsRepository.get("testuser") >> Optional.of(perm)
+
+    expect:
+    mockMvc.perform(get("/authorize/testuser/accounts/unknown-account"))
+      .andExpect(status().isNotFound())
+  }
+
+  def "GET /authorize/{userId}/applications returns user applications"() {
+    given:
+    def perm = makeUserPermissionWithApplication("testuser", "myapp")
+    permissionsRepository.get("testuser") >> Optional.of(perm)
+
+    expect:
+    mockMvc.perform(get("/authorize/testuser/applications"))
+      .andExpect(status().isOk())
+      .andExpect(jsonPath('$.length()').value(1))
+  }
+
+  def "GET /authorize/{userId}/applications/{appName} returns specific application"() {
+    given:
+    def perm = makeUserPermissionWithApplication("testuser", "myapp")
+    permissionsRepository.get("testuser") >> Optional.of(perm)
+
+    expect:
+    mockMvc.perform(get("/authorize/testuser/applications/myapp"))
+      .andExpect(status().isOk())
+      .andExpect(jsonPath('$.name').value("myapp"))
+  }
+
+  def "GET /authorize/{userId}/applications/{appName} returns 404 for unknown application"() {
+    given:
+    def perm = makeUserPermissionWithApplication("testuser", "otherapp")
+    permissionsRepository.get("testuser") >> Optional.of(perm)
+
+    expect:
+    mockMvc.perform(get("/authorize/testuser/applications/unknownapp"))
+      .andExpect(status().isNotFound())
+  }
+
+  def "GET /authorize/{userId}/roles returns user roles"() {
+    given:
+    def perm = makeUserPermissionWithRole("testuser", "developer")
+    permissionsRepository.get("testuser") >> Optional.of(perm)
+
+    expect:
+    mockMvc.perform(get("/authorize/testuser/roles"))
+      .andExpect(status().isOk())
+      .andExpect(jsonPath('$.length()').value(1))
+  }
+
+  def "GET /authorize/{userId}/serviceAccounts returns user service accounts"() {
+    given:
+    def sa = new ServiceAccount()
+    sa.name = "my-service-account"
+    def perm = makeUserPermission("testuser")
+    perm.serviceAccounts = [sa] as Set
+    permissionsRepository.get("testuser") >> Optional.of(perm)
+
+    expect:
+    mockMvc.perform(get("/authorize/testuser/serviceAccounts"))
+      .andExpect(status().isOk())
+      .andExpect(jsonPath('$.length()').value(1))
+  }
+
+  def "GET /authorize/{userId}/{resourceType}/{resourceName}/{auth} returns 200 when authorized for account"() {
+    given:
+    def account = new Account()
+    account.name = "prod-account"
+    account.permissions = Permissions.factory([(Authorization.READ): ["developer"] as Set])
+    def role = new Role()
+    role.name = "developer"
+    def perm = makeUserPermission("testuser")
+    perm.accounts = [account] as Set
+    perm.roles = [role] as Set
+    permissionsRepository.get("testuser") >> Optional.of(perm)
+
+    expect:
+    mockMvc.perform(get("/authorize/testuser/account/prod-account/read"))
+      .andExpect(status().isOk())
+  }
+
+  def "GET /authorize/{userId}/{resourceType}/{resourceName}/{auth} returns 404 when not authorized"() {
+    given:
+    def perm = makeUserPermission("testuser")
+    perm.accounts = [] as Set
+    permissionsRepository.get("testuser") >> Optional.of(perm)
+
+    expect:
+    mockMvc.perform(get("/authorize/testuser/account/prod-account/read"))
+      .andExpect(status().isNotFound())
+  }
+
+  def "POST /authorize/{userId}/{resourceType}/create returns 200 when creation is not restricted"() {
+    given:
+    configProps.restrictApplicationCreation = false
+    def perm = makeUserPermission("testuser")
+    permissionsRepository.get("testuser") >> Optional.of(perm)
+
+    expect:
+    mockMvc.perform(
+      post("/authorize/testuser/application/create")
+        .contentType(MediaType.APPLICATION_JSON)
+        .content('{"name":"newapp"}')
+    ).andExpect(status().isOk())
+  }
+
+  def "POST /authorize/{userId}/{resourceType}/create returns 400 for unsupported resource type"() {
+    given:
+    def perm = makeUserPermission("testuser")
+    permissionsRepository.get("testuser") >> Optional.of(perm)
+
+    expect:
+    mockMvc.perform(
+      post("/authorize/testuser/account/create")
+        .contentType(MediaType.APPLICATION_JSON)
+        .content('{"name":"newaccount"}')
+    ).andExpect(status().isBadRequest())
+  }
+}
