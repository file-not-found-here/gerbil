+package com.netflix.spinnaker.front50.controllers.v2
+
+import com.fasterxml.jackson.databind.ObjectMapper
+import com.netflix.spinnaker.front50.controllers.TestExceptionHandler
+import com.netflix.spinnaker.front50.model.project.Project
+import com.netflix.spinnaker.front50.model.project.ProjectDAO
+import com.netflix.spinnaker.kork.web.exceptions.NotFoundException
+import org.springframework.http.MediaType
+import org.springframework.test.web.servlet.MockMvc
+import org.springframework.test.web.servlet.setup.MockMvcBuilders
+import spock.lang.Specification
+import spock.lang.Subject
+
+import static org.springframework.test.web.servlet.request.MockMvcRequestBuilders.*
+import static org.springframework.test.web.servlet.result.MockMvcResultMatchers.*
+
+class ProjectsControllerSpec extends Specification {
+
+  ProjectDAO projectDAO = Mock()
+  ObjectMapper objectMapper = new ObjectMapper()
+  MockMvc mockMvc
+
+  @Subject
+  ProjectsController controller
+
+  void setup() {
+    controller = new ProjectsController(projectDAO)
+    mockMvc = MockMvcBuilders.standaloneSetup(controller)
+      .setControllerAdvice(new TestExceptionHandler())
+      .build()
+  }
+
+  def makeProject(String name, String id = null) {
+    def p = new Project()
+    p.name = name
+    p.id = id ?: UUID.randomUUID().toString()
+    def config = new Project.ProjectConfig()
+    config.applications = []
+    config.clusters = []
+    p.config = config
+    p.createTs = System.currentTimeMillis()
+    p.updateTs = System.currentTimeMillis()
+    return p
+  }
+
+  def "GET /v2/projects returns all projects"() {
+    given:
+    def projects = [makeProject("proj-a"), makeProject("proj-b")]
+    projectDAO.all() >> projects
+
+    expect:
+    mockMvc.perform(get("/v2/projects"))
+      .andExpect(status().isOk())
+      .andExpect(content().contentTypeCompatibleWith(MediaType.APPLICATION_JSON))
+      .andExpect(jsonPath('$.length()').value(2))
+  }
+
+  def "GET /v2/projects returns empty list when no projects exist"() {
+    given:
+    projectDAO.all() >> []
+
+    expect:
+    mockMvc.perform(get("/v2/projects"))
+      .andExpect(status().isOk())
+      .andExpect(jsonPath('$.length()').value(0))
+  }
+
+  def "GET /v2/projects?pageSize=1 limits results"() {
+    given:
+    def projects = [makeProject("proj-a"), makeProject("proj-b"), makeProject("proj-c")]
+    projectDAO.all() >> projects
+
+    expect:
+    mockMvc.perform(get("/v2/projects").param("pageSize", "1"))
+      .andExpect(status().isOk())
+      .andExpect(jsonPath('$.length()').value(1))
+  }
+
+  def "GET /v2/projects/search returns matching projects by name"() {
+    given:
+    def p1 = makeProject("myProject")
+    def p2 = makeProject("otherProject")
+    projectDAO.all() >> [p1, p2]
+
+    expect:
+    mockMvc.perform(get("/v2/projects/search").param("q", "myProject"))
+      .andExpect(status().isOk())
+      .andExpect(jsonPath('$.length()').value(1))
+      .andExpect(jsonPath('$[0].name').value("myProject"))
+  }
+
+  def "GET /v2/projects/search returns empty when no match"() {
+    given:
+    projectDAO.all() >> [makeProject("unrelated")]
+
+    expect:
+    mockMvc.perform(get("/v2/projects/search").param("q", "nomatch"))
+      .andExpect(status().isOk())
+      .andExpect(jsonPath('$.length()').value(0))
+  }
+
+  def "GET /v2/projects/{id} returns project by name first"() {
+    given:
+    def project = makeProject("myProject", "abc-123")
+    projectDAO.findByName("myProject") >> project
+
+    expect:
+    mockMvc.perform(get("/v2/projects/myProject"))
+      .andExpect(status().isOk())
+      .andExpect(jsonPath('$.name').value("myProject"))
+  }
+
+  def "GET /v2/projects/{id} falls back to findById when name lookup fails"() {
+    given:
+    def project = makeProject("myProject", "abc-123")
+    projectDAO.findByName("abc-123") >> { throw new NotFoundException("not found") }
+    projectDAO.findById("abc-123") >> project
+
+    expect:
+    mockMvc.perform(get("/v2/projects/abc-123"))
+      .andExpect(status().isOk())
+      .andExpect(jsonPath('$.name').value("myProject"))
+  }
+
+  def "GET /v2/projects/{id} returns 404 when project not found at all"() {
+    given:
+    projectDAO.findByName("noexist") >> { throw new NotFoundException("not found") }
+    projectDAO.findById("noexist") >> { throw new NotFoundException("not found") }
+
+    expect:
+    mockMvc.perform(get("/v2/projects/noexist"))
+      .andExpect(status().isNotFound())
+  }
+
+  def "POST /v2/projects creates a new project"() {
+    given:
+    def project = makeProject("newProject", "new-id")
+    projectDAO.findByName("newProject") >> { throw new NotFoundException("not found") }
+    projectDAO.create("new-id", _) >> project
+
+    when:
+    def result = mockMvc.perform(
+      post("/v2/projects")
+        .contentType(MediaType.APPLICATION_JSON)
+        .content(objectMapper.writeValueAsString(project))
+    )
+
+    then:
+    result.andExpect(status().isOk())
+      .andExpect(jsonPath('$.name').value("newProject"))
+  }
+
+  def "POST /v2/projects returns 400 when project name already exists"() {
+    given:
+    def existing = makeProject("existingProject", "existing-id")
+    def newProject = makeProject("existingProject", "new-id")
+    projectDAO.findByName("existingProject") >> existing
+
+    expect:
+    mockMvc.perform(
+      post("/v2/projects")
+        .contentType(MediaType.APPLICATION_JSON)
+        .content(objectMapper.writeValueAsString(newProject))
+    ).andExpect(status().isBadRequest())
+  }
+
+  def "PUT /v2/projects/{id} updates an existing project"() {
+    given:
+    def existing = makeProject("existingProject", "project-id")
+    def updated = makeProject("existingProject", "project-id")
+    updated.email = "updated@example.com"
+
+    projectDAO.findById("project-id") >> existing
+    projectDAO.findByName("existingProject") >> existing
+
+    when:
+    def result = mockMvc.perform(
+      put("/v2/projects/project-id")
+        .contentType(MediaType.APPLICATION_JSON)
+        .content(objectMapper.writeValueAsString(updated))
+    )
+
+    then:
+    result.andExpect(status().isOk())
+    1 * projectDAO.update("project-id", _)
+  }
+
+  def "PUT /v2/projects/{id} returns 400 when renamed project name conflicts"() {
+    given:
+    def existing = makeProject("originalName", "project-id")
+    def conflicting = makeProject("conflictName", "other-id")
+    def updated = makeProject("conflictName", "project-id")
+
+    projectDAO.findById("project-id") >> existing
+    projectDAO.findByName("conflictName") >> conflicting
+
+    expect:
+    mockMvc.perform(
+      put("/v2/projects/project-id")
+        .contentType(MediaType.APPLICATION_JSON)
+        .content(objectMapper.writeValueAsString(updated))
+    ).andExpect(status().isBadRequest())
+  }
+
+  def "DELETE /v2/projects/{id} deletes a project and returns 202"() {
+    when:
+    mockMvc.perform(delete("/v2/projects/project-id"))
+      .andExpect(status().isAccepted())
+
+    then:
+    1 * projectDAO.delete("project-id")
+  }
+
+  def "POST /v2/projects/batchUpdate bulk imports projects and returns 202"() {
+    given:
+    def projects = [makeProject("p1"), makeProject("p2")]
+
+    when:
+    mockMvc.perform(
+      post("/v2/projects/batchUpdate")
+        .contentType(MediaType.APPLICATION_JSON)
+        .content(objectMapper.writeValueAsString(projects))
+    ).andExpect(status().isAccepted())
+
+    then:
+    1 * projectDAO.bulkImport(_)
+  }
+}
