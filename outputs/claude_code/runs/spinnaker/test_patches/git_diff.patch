+      .setControllerAdvice(new TestExceptionHandler())
+      .build()
+  }
+
+  def makeStrategy(String application, String name, String id = null) {
+    def p = new Pipeline()
+    p.application = application
+    p.name = name
+    p.id = id ?: UUID.randomUUID().toString()
+    return p
+  }
+
+  def "GET /strategies lists all strategies"() {
+    given:
+    def strategies = [makeStrategy("app1", "strat-a"), makeStrategy("app2", "strat-b")]
+    pipelineStrategyDAO.all() >> strategies
+
+    expect:
+    mockMvc.perform(get("/strategies"))
+      .andExpect(status().isOk())
+      .andExpect(content().contentTypeCompatibleWith(MediaType.APPLICATION_JSON))
+      .andExpect(jsonPath('$.length()').value(2))
+  }
+
+  def "GET /strategies/{application} lists strategies for the given application"() {
+    given:
+    def strategies = [makeStrategy("myapp", "strat-1"), makeStrategy("myapp", "strat-2")]
+    pipelineStrategyDAO.getPipelinesByApplication("myapp") >> strategies
+
+    expect:
+    mockMvc.perform(get("/strategies/myapp"))
+      .andExpect(status().isOk())
+      .andExpect(jsonPath('$.length()').value(2))
+      .andExpect(jsonPath('$[0].application').value("myapp"))
+  }
+
+  def "GET /strategies/{application} returns empty list for unknown application"() {
+    given:
+    pipelineStrategyDAO.getPipelinesByApplication("unknown") >> []
+
+    expect:
+    mockMvc.perform(get("/strategies/unknown"))
+      .andExpect(status().isOk())
+      .andExpect(jsonPath('$.length()').value(0))
+  }
+
+  def "GET /strategies/{id}/history returns version history"() {
+    given:
+    def strategies = [makeStrategy("app1", "strat-a"), makeStrategy("app1", "strat-a")]
+    pipelineStrategyDAO.history("strat-id", 20) >> strategies
+
+    expect:
+    mockMvc.perform(get("/strategies/strat-id/history"))
+      .andExpect(status().isOk())
+      .andExpect(jsonPath('$.length()').value(2))
+  }
+
+  def "GET /strategies/{id}/history respects limit parameter"() {
+    when:
+    mockMvc.perform(get("/strategies/strat-id/history").param("limit", "5"))
+      .andExpect(status().isOk())
+
+    then:
+    1 * pipelineStrategyDAO.history("strat-id", 5) >> [makeStrategy("app1", "strat-a")]
+  }
+
+  def "POST /strategies saves a new strategy"() {
+    given:
+    def strategy = makeStrategy("myapp", "new-strategy")
+    pipelineStrategyDAO.getPipelinesByApplication("myapp") >> []
+    pipelineStrategyDAO.create(_, _) >> strategy
+
+    when:
+    def result = mockMvc.perform(
+      post("/strategies")
+        .contentType(MediaType.APPLICATION_JSON)
+        .content(objectMapper.writeValueAsString(strategy))
+    )
+
+    then:
+    result.andExpect(status().isOk())
+  }
+
+  def "POST /strategies rejects duplicate strategy name"() {
+    given:
+    def existing = makeStrategy("myapp", "existing-strategy", "existing-id")
+    def newStrategy = makeStrategy("myapp", "existing-strategy")
+    newStrategy.id = null  // new strategy has no id
+
+    pipelineStrategyDAO.getPipelinesByApplication("myapp") >> [existing]
+
+    expect:
+    mockMvc.perform(
+      post("/strategies")
+        .contentType(MediaType.APPLICATION_JSON)
+        .content(objectMapper.writeValueAsString(newStrategy))
+    ).andExpect(status().isBadRequest())
+  }
+
+  def "POST /strategies/batchUpdate performs batch import"() {
+    given:
+    def strategies = [makeStrategy("app1", "strat-a"), makeStrategy("app1", "strat-b")]
+
+    when:
+    def result = mockMvc.perform(
+      post("/strategies/batchUpdate")
+        .contentType(MediaType.APPLICATION_JSON)
+        .content(objectMapper.writeValueAsString(strategies))
+    )
+
+    then:
+    result.andExpect(status().isOk())
+    1 * pipelineStrategyDAO.bulkImport(_)
+  }
+
+  def "PUT /strategies/{id} updates an existing strategy"() {
+    given:
+    def existing = makeStrategy("myapp", "my-strategy", "strat-id")
+    def updated = makeStrategy("myapp", "my-strategy", "strat-id")
+    updated.email = "updated@example.com"
+
+    pipelineStrategyDAO.findById("strat-id") >> existing
+    pipelineStrategyDAO.getPipelinesByApplication("myapp") >> []
+
+    when:
+    def result = mockMvc.perform(
+      put("/strategies/strat-id")
+        .contentType(MediaType.APPLICATION_JSON)
+        .content(objectMapper.writeValueAsString(updated))
+    )
+
+    then:
+    result.andExpect(status().isOk())
+    1 * pipelineStrategyDAO.update("strat-id", _)
+  }
+
+  def "DELETE /strategies/{application}/{strategy} deletes a strategy"() {
+    given:
+    pipelineStrategyDAO.getPipelineId("myapp", "my-strategy") >> "strat-id"
+
+    when:
+    def result = mockMvc.perform(delete("/strategies/myapp/my-strategy"))
+
+    then:
+    result.andExpect(status().isOk())
+    1 * pipelineStrategyDAO.delete("strat-id")
+  }
