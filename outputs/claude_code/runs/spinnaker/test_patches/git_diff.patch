+    mockMvc.perform(get("/v2/applications").param("restricted", "false").param("pageSize", "1"))
+      .andExpect(status().isOk())
+      .andExpect(jsonPath('$.length()').value(1))
+  }
+
+  def "GET /v2/applications?name=myapp searches by attribute"() {
+    given:
+    def apps = [makeApp("MYAPP")]
+    applicationDAO.search(["name": "myapp"]) >> apps
+    applicationPermissionDAO.all() >> []
+
+    expect:
+    mockMvc.perform(get("/v2/applications").param("restricted", "false").param("name", "myapp"))
+      .andExpect(status().isOk())
+      .andExpect(jsonPath('$.length()').value(1))
+  }
+
+  def "GET /v2/applications/{name} returns a specific application"() {
+    given:
+    def app = makeApp("MYAPP")
+    applicationDAO.findByName("MYAPP") >> app
+    applicationPermissionDAO.findById("MYAPP") >> { throw new NotFoundException("not found") }
+
+    expect:
+    mockMvc.perform(get("/v2/applications/MYAPP"))
+      .andExpect(status().isOk())
+      .andExpect(jsonPath('$.name').value("MYAPP"))
+  }
+
+  def "GET /v2/applications/{name} returns 404 when not found"() {
+    given:
+    applicationDAO.findByName("NOEXIST") >> { throw new NotFoundException("not found") }
+
+    expect:
+    mockMvc.perform(get("/v2/applications/NOEXIST"))
+      .andExpect(status().isNotFound())
+  }
+
+  def "GET /v2/applications/{name}/history returns application history"() {
+    given:
+    def history = [makeApp("MYAPP"), makeApp("MYAPP")]
+    applicationDAO.history("myapp", 20) >> history
+
+    expect:
+    mockMvc.perform(get("/v2/applications/myapp/history"))
+      .andExpect(status().isOk())
+      .andExpect(jsonPath('$.length()').value(2))
+  }
+
+  def "GET /v2/applications/{name}/history respects limit parameter"() {
+    when:
+    mockMvc.perform(get("/v2/applications/myapp/history").param("limit", "5"))
+      .andExpect(status().isOk())
+
+    then:
+    1 * applicationDAO.history("myapp", 5) >> [makeApp("MYAPP")]
+  }
+
+  def "POST /v2/applications creates a new application"() {
+    given:
+    def app = makeApp("NEWAPP")
+    applicationService.findByName("NEWAPP") >> null
+    applicationService.save(_) >> app
+
+    when:
+    def result = mockMvc.perform(
+      post("/v2/applications")
+        .contentType(MediaType.APPLICATION_JSON)
+        .content(objectMapper.writeValueAsString(app))
+    )
+
+    then:
+    result.andExpect(status().isOk())
+      .andExpect(jsonPath('$.name').value("NEWAPP"))
+  }
+
+  def "POST /v2/applications returns 400 when application already exists"() {
+    given:
+    def app = makeApp("EXISTING")
+    applicationService.findByName("EXISTING") >> app
+    // The controller throws ApplicationAlreadyExistsException
+    applicationService.save(_) >> { throw new ApplicationAlreadyExistsException() }
+
+    expect:
+    mockMvc.perform(
+      post("/v2/applications")
+        .contentType(MediaType.APPLICATION_JSON)
+        .content(objectMapper.writeValueAsString(app))
+    ).andExpect(status().isBadRequest())
+  }
+
+  def "PATCH /v2/applications/{name} updates an existing application"() {
+    given:
+    def app = makeApp("MYAPP")
+    app.email = "updated@example.com"
+    applicationService.save(app) >> app
+
+    when:
+    def result = mockMvc.perform(
+      patch("/v2/applications/MYAPP")
+        .contentType(MediaType.APPLICATION_JSON)
+        .content(objectMapper.writeValueAsString(app))
+    )
+
+    then:
+    result.andExpect(status().isOk())
+  }
+
+  def "PATCH /v2/applications/{name} returns 400 when name in body does not match path"() {
+    given:
+    def app = makeApp("DIFFERENTAPP")
+
+    expect:
+    mockMvc.perform(
+      patch("/v2/applications/MYAPP")
+        .contentType(MediaType.APPLICATION_JSON)
+        .content(objectMapper.writeValueAsString(app))
+    ).andExpect(status().isBadRequest())
+  }
+
+  def "PUT /v2/applications/{name} replaces an existing application"() {
+    given:
+    def app = makeApp("MYAPP")
+    applicationService.replace(app) >> app
+
+    when:
+    def result = mockMvc.perform(
+      put("/v2/applications/MYAPP")
+        .contentType(MediaType.APPLICATION_JSON)
+        .content(objectMapper.writeValueAsString(app))
+    )
+
+    then:
+    result.andExpect(status().isOk())
+  }
+
+  def "PUT /v2/applications/{name} returns 400 when name mismatch"() {
+    given:
+    def app = makeApp("DIFFERENTAPP")
+
+    expect:
+    mockMvc.perform(
+      put("/v2/applications/MYAPP")
+        .contentType(MediaType.APPLICATION_JSON)
+        .content(objectMapper.writeValueAsString(app))
+    ).andExpect(status().isBadRequest())
+  }
+
+  def "DELETE /v2/applications/{name} deletes an application and returns 204"() {
+    when:
+    def result = mockMvc.perform(delete("/v2/applications/MYAPP"))
+
+    then:
+    result.andExpect(status().isNoContent())
+    1 * applicationService.delete("MYAPP")
+  }
+
+  def "POST /v2/applications/batch/applications bulk imports applications"() {
+    given:
+    def apps = [makeApp("APP1"), makeApp("APP2")]
+
+    when:
+    def result = mockMvc.perform(
+      post("/v2/applications/batch/applications")
+        .contentType(MediaType.APPLICATION_JSON)
+        .content(objectMapper.writeValueAsString(apps))
+    )
+
+    then:
+    result.andExpect(status().isOk())
+    1 * applicationDAO.bulkImport(_)
+  }
+}
