+package com.netflix.spinnaker.fiat.controllers
+
+import com.netflix.spinnaker.kork.web.exceptions.InvalidRequestException
+import com.netflix.spinnaker.kork.web.exceptions.NotFoundException
+import org.springframework.http.HttpStatus
+import org.springframework.web.bind.annotation.ControllerAdvice
+import org.springframework.web.bind.annotation.ExceptionHandler
+import org.springframework.web.bind.annotation.ResponseStatus
+
+@ControllerAdvice
+class FiatTestExceptionHandler {
+
+  @ExceptionHandler(NotFoundException)
+  @ResponseStatus(HttpStatus.NOT_FOUND)
+  void handleNotFound(NotFoundException e) {}
+
+  @ExceptionHandler(InvalidRequestException)
+  @ResponseStatus(HttpStatus.BAD_REQUEST)
+  void handleBadRequest(InvalidRequestException e) {}
+
+  @ExceptionHandler(IllegalArgumentException)
+  @ResponseStatus(HttpStatus.BAD_REQUEST)
+  void handleIllegalArgument(IllegalArgumentException e) {}
+}
