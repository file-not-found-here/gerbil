+@RunWith(PowerMockRunner.class)
+@PrepareForTest({ KylinConfig.class })
+public class NMonitorControllerTest {
+
+    private MockMvc mockMvc;
+    private final ObjectMapper objectMapper = new ObjectMapper();
+
+    @Mock
+    private MonitorService monitorService;
+    @Mock
+    private RestTemplate normalRestTemplate;
+    @Mock
+    private ProjectService projectService;
+    @Mock
+    private UserService userService;
+    @Mock
+    private KylinConfig kylinConfig;
+
+    @InjectMocks
+    private NMonitorController controller;
+
+    @Before
+    public void setUp() {
+        PowerMockito.mockStatic(KylinConfig.class);
+        when(KylinConfig.getInstanceFromEnv()).thenReturn(kylinConfig);
+        when(kylinConfig.getDataBinderAutoGrowCollectionLimit()).thenReturn(256);
+
+        ReflectionTestUtils.setField(controller, "restTemplate", normalRestTemplate);
+        ReflectionTestUtils.setField(controller, "projectService", projectService);
+        ReflectionTestUtils.setField(controller, "userService", userService);
+        mockMvc = MockMvcBuilders.standaloneSetup(controller).build();
+    }
+
+    @Test
+    public void testGetMemoryMetrics_returnsEmptyList() throws Exception {
+        mockMvc.perform(get("/api/monitor/memory_info")
+                .accept("application/vnd.apache.kylin-v4+json"))
+                .andExpect(status().isOk())
+                .andExpect(jsonPath("$.code").value("000"));
+    }
+
+    @Test
+    public void testGetThreadInfoMetrics_returnsEmptyList() throws Exception {
+        mockMvc.perform(get("/api/monitor/thread_info")
+                .accept("application/vnd.apache.kylin-v4+json"))
+                .andExpect(status().isOk())
+                .andExpect(jsonPath("$.code").value("000"));
+    }
+
+    @Test
+    public void testGetClusterCurrentStatus_delegatesToMonitorService() throws Exception {
+        ClusterStatusResponse clusterStatus = mock(ClusterStatusResponse.class);
+        when(monitorService.currentClusterStatus()).thenReturn(clusterStatus);
+
+        mockMvc.perform(get("/api/monitor/status")
+                .accept("application/vnd.apache.kylin-v4+json"))
+                .andExpect(status().isOk())
+                .andExpect(jsonPath("$.code").value("000"));
+
+        verify(monitorService, times(1)).currentClusterStatus();
+    }
+
+    @Test
+    public void testGetClusterStatisticStatus_validRange() throws Exception {
+        long now = System.currentTimeMillis();
+        long start = now - 10_000;
+        long end = now - 5_000;
+
+        ClusterStatisticStatusResponse response = mock(ClusterStatisticStatusResponse.class);
+        when(monitorService.statisticClusterByFloorTime(start, end)).thenReturn(response);
+
+        mockMvc.perform(get("/api/monitor/status/statistics")
+                .param("start", String.valueOf(start))
+                .param("end", String.valueOf(end))
+                .accept("application/vnd.apache.kylin-v4+json"))
+                .andExpect(status().isOk())
+                .andExpect(jsonPath("$.code").value("000"));
+
+        verify(monitorService, times(1)).statisticClusterByFloorTime(start, end);
+    }
+
+    @Test
+    public void testGetClusterStatisticStatus_startAfterEnd_returns500() throws Exception {
+        long now = System.currentTimeMillis();
+        long start = now;
+        long end = now - 5_000;
+
+        mockMvc.perform(get("/api/monitor/status/statistics")
+                .param("start", String.valueOf(start))
+                .param("end", String.valueOf(end))
+                .accept("application/vnd.apache.kylin-v4+json"))
+                .andExpect(status().is5xxServerError());
+    }
+
+    @Test
+    public void testAlert_validRequest_delegatesToMonitorService() throws Exception {
+        AlertMessageRequest.Labels labels = new AlertMessageRequest.Labels();
+        AlertMessageRequest.Alerts alert = new AlertMessageRequest.Alerts();
+        alert.setLabels(labels);
+
+        AlertMessageRequest request = new AlertMessageRequest();
+        request.setAlerts(Collections.singletonList(alert));
+
+        doNothing().when(monitorService).handleAlertMessage(any(AlertMessageRequest.class));
+
+        mockMvc.perform(post("/api/monitor/alert")
+                .contentType(MediaType.APPLICATION_JSON)
+                .content(objectMapper.writeValueAsString(request))
+                .accept("application/vnd.apache.kylin-v4+json"))
+                .andExpect(status().isOk());
+
+        verify(monitorService, times(1)).handleAlertMessage(any(AlertMessageRequest.class));
+    }
+}
