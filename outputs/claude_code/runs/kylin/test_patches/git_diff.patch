+import org.springframework.web.client.RestTemplate;
+
+@RunWith(PowerMockRunner.class)
+@PrepareForTest({ KylinConfig.class, ResourceGroupManager.class })
+public class NAdminControllerTest {
+
+    private MockMvc mockMvc;
+
+    @Mock
+    private KylinConfig kylinConfig;
+    @Mock
+    private ResourceGroupManager resourceGroupManager;
+    @Mock
+    private RestTemplate normalRestTemplate;
+    @Mock
+    private ProjectService projectService;
+    @Mock
+    private UserService userService;
+
+    @InjectMocks
+    private NAdminController controller;
+
+    @Before
+    public void setUp() throws Exception {
+        PowerMockito.mockStatic(KylinConfig.class);
+        PowerMockito.mockStatic(ResourceGroupManager.class);
+
+        when(KylinConfig.getInstanceFromEnv()).thenReturn(kylinConfig);
+        when(kylinConfig.getPropertiesWhiteList()).thenReturn("");
+        when(kylinConfig.exportToString(org.mockito.ArgumentMatchers.anyCollection())).thenReturn("");
+        when(kylinConfig.isAllowedNonAdminGenerateQueryDiagPackage()).thenReturn(true);
+        when(kylinConfig.isStreamingEnabled()).thenReturn(false);
+        when(kylinConfig.getTimeZone()).thenReturn("UTC");
+        when(ResourceGroupManager.getInstance(kylinConfig)).thenReturn(resourceGroupManager);
+        when(resourceGroupManager.isResourceGroupEnabled()).thenReturn(false);
+
+        ReflectionTestUtils.setField(controller, "restTemplate", normalRestTemplate);
+        ReflectionTestUtils.setField(controller, "projectService", projectService);
+        ReflectionTestUtils.setField(controller, "userService", userService);
+        mockMvc = MockMvcBuilders.standaloneSetup(controller).build();
+    }
+
+    @Test
+    public void testGetPublicConfig_returnsSuccessCode() throws Exception {
+        mockMvc.perform(get("/api/admin/public_config")
+                .accept("application/vnd.apache.kylin-v4+json"))
+                .andExpect(status().isOk())
+                .andExpect(jsonPath("$.code").value("000"));
+    }
+
+    @Test
+    public void testGetInstanceConfig_returnsTimezone() throws Exception {
+        mockMvc.perform(get("/api/admin/instance_info")
+                .accept("application/vnd.apache.kylin-v4+json"))
+                .andExpect(status().isOk())
+                .andExpect(jsonPath("$.code").value("000"))
+                .andExpect(jsonPath("$.data['instance.timezone']").value("UTC"));
+    }
+
+    @Test
+    public void testGetPublicConfig_responseContainsKylinStreaming() throws Exception {
+        when(kylinConfig.isStreamingEnabled()).thenReturn(true);
+
+        mockMvc.perform(get("/api/admin/public_config")
+                .accept("application/vnd.apache.kylin-v4+json"))
+                .andExpect(status().isOk())
+                .andExpect(jsonPath("$.code").value("000"));
+    }
+}
