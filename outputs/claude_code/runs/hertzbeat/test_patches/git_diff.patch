+package org.apache.hertzbeat.manager.controller;
+
+import static org.assertj.core.api.Assertions.assertThat;
+
+import java.util.ArrayList;
+import java.util.HashMap;
+import java.util.List;
+import java.util.Map;
+import org.junit.jupiter.api.Test;
+import org.springframework.beans.factory.annotation.Autowired;
+import org.springframework.boot.test.context.SpringBootTest;
+import org.springframework.boot.test.web.client.TestRestTemplate;
+import org.springframework.http.HttpMethod;
+import org.springframework.http.HttpStatus;
+import org.springframework.http.ResponseEntity;
+import org.springframework.test.context.ActiveProfiles;
+
+/**
+ * Integration tests for MonitorController.
+ * POST /api/monitor          - add monitor
+ * PUT  /api/monitor          - modify monitor
+ * GET  /api/monitor/{id}     - get monitor by id
+ * DELETE /api/monitor/{id}   - delete monitor
+ * POST /api/monitor/detect   - detect availability
+ * POST /api/monitor/copy/{id}- copy monitor
+ */
+@SpringBootTest(webEnvironment = SpringBootTest.WebEnvironment.RANDOM_PORT)
+@ActiveProfiles("test")
+class MonitorControllerTest {
+
+    @Autowired
+    private TestRestTemplate restTemplate;
+
+    private TestRestTemplate admin() {
+        return restTemplate.withBasicAuth("admin", "hertzbeat");
+    }
+
+    private Map<String, Object> buildWebsiteMonitorDto(String name, String host) {
+        Map<String, Object> monitor = new HashMap<>();
+        monitor.put("app", "website");
+        monitor.put("host", host);
+        monitor.put("name", name);
+        monitor.put("intervals", 60);
+        monitor.put("status", 1);
+
+        List<Map<String, Object>> params = new ArrayList<>();
+        addParam(params, "host", host, 1);
+        addParam(params, "port", "80", 0);
+        addParam(params, "httpMethod", "GET", 1);
+        addParam(params, "uri", "/", 1);
+        addParam(params, "ssl", "false", 1);
+        addParam(params, "timeout", "6000", 0);
+        addParam(params, "authType", "Basic Auth", 1);
+
+        Map<String, Object> dto = new HashMap<>();
+        dto.put("monitor", monitor);
+        dto.put("params", params);
+        return dto;
+    }
+
+    private void addParam(List<Map<String, Object>> params, String field, String value, int type) {
+        Map<String, Object> param = new HashMap<>();
+        param.put("field", field);
+        param.put("paramValue", value);
+        param.put("type", type);
+        params.add(param);
+    }
+
+    @Test
+    void getMonitor_nonExistentId_returnsNotExistCode() {
+        ResponseEntity<Map> response = admin().getForEntity(
+                "/api/monitor/999999999", Map.class);
+
+        assertThat(response.getStatusCode()).isEqualTo(HttpStatus.OK);
+        Map<?, ?> body = response.getBody();
+        assertThat(body).isNotNull();
+        // MONITOR_NOT_EXIST_CODE = 3
+        assertThat(((Number) body.get("code")).intValue()).isEqualTo(3);
+    }
+
+    @Test
+    void getMonitor_withoutAuth_returnsUnauthorized() {
+        ResponseEntity<Map> response = restTemplate.getForEntity(
+                "/api/monitor/1", Map.class);
+
+        assertThat(response.getStatusCode().value()).isGreaterThanOrEqualTo(400);
+    }
+
+    @Test
+    void addMonitor_validWebsiteMonitor_returnsSuccess() {
+        Map<String, Object> dto = buildWebsiteMonitorDto(
+                "test-website-monitor-add", "example.com");
+
+        ResponseEntity<Map> response = admin().postForEntity("/api/monitor", dto, Map.class);
+
+        assertThat(response.getStatusCode()).isEqualTo(HttpStatus.OK);
+        assertThat(((Number) response.getBody().get("code")).intValue()).isZero();
+        assertThat(response.getBody().get("msg")).isEqualTo("Add success");
+    }
+
+    @Test
+    void addMonitor_missingParams_returnsBadRequest() {
+        Map<String, Object> dto = new HashMap<>();
+        // Missing required 'monitor' and 'params' fields
+        dto.put("collector", "main-default-collector");
+
+        ResponseEntity<Map> response = admin().postForEntity("/api/monitor", dto, Map.class);
+
+        assertThat(response.getStatusCode().value()).isGreaterThanOrEqualTo(400);
+    }
+
+    @Test
+    void addAndGetMonitor_success() {
+        String monitorName = "test-website-add-and-get";
+        Map<String, Object> dto = buildWebsiteMonitorDto(monitorName, "127.0.0.1");
+
+        ResponseEntity<Map> addResponse = admin().postForEntity("/api/monitor", dto, Map.class);
+        assertThat(addResponse.getStatusCode()).isEqualTo(HttpStatus.OK);
+        assertThat(((Number) addResponse.getBody().get("code")).intValue()).isZero();
+
+        // Query monitors list to find the created monitor's ID
+        ResponseEntity<Map> listResponse = admin().getForEntity(
+                "/api/monitors?search=" + monitorName + "&pageIndex=0&pageSize=10", Map.class);
+        assertThat(listResponse.getStatusCode()).isEqualTo(HttpStatus.OK);
+        @SuppressWarnings("unchecked")
+        Map<String, Object> pageData = (Map<String, Object>) listResponse.getBody().get("data");
+        @SuppressWarnings("unchecked")
+        List<Map<String, Object>> content = (List<Map<String, Object>>) pageData.get("content");
+
+        if (content != null && !content.isEmpty()) {
+            Number monitorId = (Number) content.get(0).get("id");
+
+            // Get the specific monitor
+            ResponseEntity<Map> getResponse = admin().getForEntity(
+                    "/api/monitor/" + monitorId.longValue(), Map.class);
+            assertThat(getResponse.getStatusCode()).isEqualTo(HttpStatus.OK);
+            assertThat(((Number) getResponse.getBody().get("code")).intValue()).isZero();
+
+            @SuppressWarnings("unchecked")
+            Map<String, Object> monitorDto = (Map<String, Object>) getResponse.getBody().get("data");
+            assertThat(monitorDto).isNotNull();
+            @SuppressWarnings("unchecked")
+            Map<String, Object> monitor = (Map<String, Object>) monitorDto.get("monitor");
+            assertThat(monitor).isNotNull();
+            assertThat(monitor.get("name")).isEqualTo(monitorName);
+        }
+    }
+
+    @Test
+    void addAndDeleteMonitor_success() {
+        String monitorName = "test-monitor-to-delete";
+        Map<String, Object> dto = buildWebsiteMonitorDto(monitorName, "127.0.0.1");
+
+        admin().postForEntity("/api/monitor", dto, Map.class);
+
+        // Find the monitor
+        ResponseEntity<Map> listResponse = admin().getForEntity(
+                "/api/monitors?search=" + monitorName + "&pageIndex=0&pageSize=10", Map.class);
+        @SuppressWarnings("unchecked")
+        Map<String, Object> pageData = (Map<String, Object>) listResponse.getBody().get("data");
+        @SuppressWarnings("unchecked")
+        List<Map<String, Object>> content = (List<Map<String, Object>>) pageData.get("content");
+
+        if (content != null && !content.isEmpty()) {
+            Number monitorId = (Number) content.get(0).get("id");
+
+            ResponseEntity<Map> deleteResponse = admin().exchange(
+                    "/api/monitor/" + monitorId.longValue(),
+                    HttpMethod.DELETE, null, Map.class);
+
+            assertThat(deleteResponse.getStatusCode()).isEqualTo(HttpStatus.OK);
+            assertThat(((Number) deleteResponse.getBody().get("code")).intValue()).isZero();
+
+            // Verify monitor is gone
+            ResponseEntity<Map> getResponse = admin().getForEntity(
+                    "/api/monitor/" + monitorId.longValue(), Map.class);
+            assertThat(((Number) getResponse.getBody().get("code")).intValue()).isEqualTo(3);
+        }
+    }
+
+    @Test
+    void deleteMonitor_nonExistent_returnsSuccess() {
+        ResponseEntity<Map> response = admin().exchange(
+                "/api/monitor/999999998", HttpMethod.DELETE, null, Map.class);
+
+        assertThat(response.getStatusCode()).isEqualTo(HttpStatus.OK);
+        assertThat(((Number) response.getBody().get("code")).intValue()).isZero();
+    }
+
+    @Test
+    void copyMonitor_nonExistent_returnsFailCode() {
+        ResponseEntity<Map> response = admin().postForEntity(
+                "/api/monitor/copy/999999999", null, Map.class);
+
+        assertThat(response.getStatusCode()).isEqualTo(HttpStatus.OK);
+        // Copy of non-existent monitor should fail
+        assertThat(((Number) response.getBody().get("code")).intValue()).isNotZero();
+    }
+}
