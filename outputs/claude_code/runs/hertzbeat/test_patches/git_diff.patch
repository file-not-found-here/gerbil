+import org.springframework.boot.test.web.client.TestRestTemplate;
+import org.springframework.http.HttpStatus;
+import org.springframework.http.ResponseEntity;
+import org.springframework.test.context.ActiveProfiles;
+
+/**
+ * Integration tests for warehouse data controllers.
+ * POST /api/warehouse/query                          - DataQueryController: query datasource data
+ * GET  /api/warehouse/storage/status                 - MetricsDataController: get storage status
+ * GET  /api/monitor/{monitorId}/metrics/{metrics}    - MetricsDataController: get metrics data
+ * GET  /api/monitor/{monitorId}/metric/{metricFull}  - MetricsDataController: get metric history
+ */
+@SpringBootTest(webEnvironment = SpringBootTest.WebEnvironment.RANDOM_PORT)
+@ActiveProfiles("test")
+class WarehouseControllerTest {
+
+    @Autowired
+    private TestRestTemplate restTemplate;
+
+    private TestRestTemplate admin() {
+        return restTemplate.withBasicAuth("admin", "hertzbeat");
+    }
+
+    @Test
+    void getStorageStatus_returnsResponse() {
+        ResponseEntity<Map> response = admin().getForEntity(
+                "/api/warehouse/storage/status", Map.class);
+
+        assertThat(response.getStatusCode()).isEqualTo(HttpStatus.OK);
+        assertThat(response.getBody()).isNotNull();
+        assertThat(((Number) response.getBody().get("code")).intValue()).isZero();
+    }
+
+    @Test
+    void getMetricsData_nonExistentMonitor_returnsResponse() {
+        ResponseEntity<Map> response = admin().getForEntity(
+                "/api/monitor/999999999/metrics/website", Map.class);
+
+        assertThat(response.getStatusCode()).isEqualTo(HttpStatus.OK);
+        assertThat(response.getBody()).isNotNull();
+    }
+
+    @Test
+    void getMetricHistory_nonExistentMonitor_returnsResponse() {
+        ResponseEntity<Map> response = admin().getForEntity(
+                "/api/monitor/999999999/metric/website.summary.responseTime", Map.class);
+
+        assertThat(response.getStatusCode()).isEqualTo(HttpStatus.OK);
+        assertThat(response.getBody()).isNotNull();
+    }
+
+    @Test
+    void getMetricHistory_withIntervalParam_returnsResponse() {
+        ResponseEntity<Map> response = admin().getForEntity(
+                "/api/monitor/999999999/metric/website.summary.responseTime?interval=true&history=6h",
+                Map.class);
+
+        assertThat(response.getStatusCode()).isEqualTo(HttpStatus.OK);
+        assertThat(response.getBody()).isNotNull();
+    }
+
+    @Test
+    void queryDatasource_withEmptyList_returnsResponse() {
+        ResponseEntity<Map> response = admin().postForEntity(
+                "/api/warehouse/query", Arrays.asList(), Map.class);
+
+        assertThat(response.getStatusCode()).isEqualTo(HttpStatus.OK);
+        assertThat(response.getBody()).isNotNull();
+    }
+
+    @Test
+    void queryDatasource_withRequest_returnsResponse() {
+        Map<String, Object> query = new HashMap<>();
+        query.put("monitorId", 999999999L);
+        query.put("app", "website");
+        query.put("metric", "summary");
+        query.put("field", "responseTime");
+
+        ResponseEntity<Map> response = admin().postForEntity(
+                "/api/warehouse/query", Arrays.asList(query), Map.class);
+
+        assertThat(response.getStatusCode()).isEqualTo(HttpStatus.OK);
+        assertThat(response.getBody()).isNotNull();
+    }
+
+    @Test
+    void getStorageStatus_withoutAuth_returnsUnauthorized() {
+        ResponseEntity<Map> response = restTemplate.getForEntity(
+                "/api/warehouse/storage/status", Map.class);
+
+        assertThat(response.getStatusCode().value()).isGreaterThanOrEqualTo(400);
+    }
+}
