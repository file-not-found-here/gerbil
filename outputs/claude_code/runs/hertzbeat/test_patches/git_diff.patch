+package org.apache.hertzbeat.manager.controller;
+
+import static org.assertj.core.api.Assertions.assertThat;
+
+import java.util.Map;
+import org.junit.jupiter.api.Test;
+import org.springframework.beans.factory.annotation.Autowired;
+import org.springframework.boot.test.context.SpringBootTest;
+import org.springframework.boot.test.web.client.TestRestTemplate;
+import org.springframework.http.HttpEntity;
+import org.springframework.http.HttpHeaders;
+import org.springframework.http.HttpStatus;
+import org.springframework.http.MediaType;
+import org.springframework.http.ResponseEntity;
+import org.springframework.test.context.ActiveProfiles;
+
+/**
+ * Integration tests for AlertReportController.
+ * POST /api/alerts/report              - receive default external alert (public)
+ * POST /api/alerts/report/{source}     - receive external alert with source (public)
+ * POST /api/v2/alerts                  - receive Prometheus alert (public)
+ */
+@SpringBootTest(webEnvironment = SpringBootTest.WebEnvironment.RANDOM_PORT)
+@ActiveProfiles("test")
+class AlertReportControllerTest {
+
+    @Autowired
+    private TestRestTemplate restTemplate;
+
+    private HttpEntity<String> jsonBody(String json) {
+        HttpHeaders headers = new HttpHeaders();
+        headers.setContentType(MediaType.APPLICATION_JSON);
+        return new HttpEntity<>(json, headers);
+    }
+
+    @Test
+    void receiveDefaultExternAlert_withEmptyJson_returnsResponse() {
+        ResponseEntity<Map> response = restTemplate.postForEntity(
+                "/api/alerts/report", jsonBody("{}"), Map.class);
+
+        assertThat(response.getStatusCode()).isEqualTo(HttpStatus.OK);
+        assertThat(response.getBody()).isNotNull();
+        assertThat(response.getBody().get("code")).isNotNull();
+    }
+
+    @Test
+    void receiveDefaultExternAlert_publicEndpointNoAuth() {
+        // This endpoint is excluded from auth (public)
+        ResponseEntity<Map> response = restTemplate.postForEntity(
+                "/api/alerts/report", jsonBody("{\"status\":\"firing\"}"), Map.class);
+
+        // Public endpoint - should not return 401
+        assertThat(response.getStatusCode().value()).isNotEqualTo(401);
+        assertThat(response.getStatusCode().value()).isNotEqualTo(403);
+    }
+
+    @Test
+    void receiveExternAlertWithSource_prometheusSource() {
+        String alertPayload = "{\"status\":\"firing\",\"labels\":{\"alertname\":\"TestAlert\"}}";
+
+        ResponseEntity<Map> response = restTemplate.postForEntity(
+                "/api/alerts/report/prometheus", jsonBody(alertPayload), Map.class);
+
+        assertThat(response.getStatusCode()).isEqualTo(HttpStatus.OK);
+        assertThat(response.getBody()).isNotNull();
+    }
+
+    @Test
+    void receiveExternAlertWithSource_huaweicloudSource() {
+        String alertPayload = "{\"events\":[{\"alarm_name\":\"TestAlarm\"}]}";
+
+        ResponseEntity<Map> response = restTemplate.postForEntity(
+                "/api/alerts/report/huaweicloud", jsonBody(alertPayload), Map.class);
+
+        // Not all source parsers accept arbitrary JSON; just verify the endpoint is reachable
+        assertThat(response.getStatusCode().value()).isNotEqualTo(401);
+        assertThat(response.getStatusCode().value()).isNotEqualTo(403);
+        assertThat(response.getBody()).isNotNull();
+    }
+
+    @Test
+    void receivePrometheusServerAlert_validFormat() {
+        // /api/v2/alerts is NOT in sureness excludedResource, so it requires auth
+        String prometheusAlerts = "[{\"labels\":{\"alertname\":\"TestAlert\",\"severity\":\"critical\"},"
+                + "\"annotations\":{\"summary\":\"Test alert\"},"
+                + "\"status\":\"firing\","
+                + "\"startsAt\":\"2024-01-01T00:00:00Z\"}]";
+
+        ResponseEntity<Map> response = restTemplate
+                .withBasicAuth("admin", "hertzbeat")
+                .postForEntity("/api/v2/alerts", jsonBody(prometheusAlerts), Map.class);
+
+        assertThat(response.getStatusCode()).isEqualTo(HttpStatus.OK);
+        assertThat(response.getBody()).isNotNull();
+    }
+
+    @Test
+    void receivePrometheusServerAlert_emptyArray() {
+        // /api/v2/alerts requires auth
+        ResponseEntity<Map> response = restTemplate
+                .withBasicAuth("admin", "hertzbeat")
+                .postForEntity("/api/v2/alerts", jsonBody("[]"), Map.class);
+
+        assertThat(response.getStatusCode()).isEqualTo(HttpStatus.OK);
+        assertThat(response.getBody()).isNotNull();
+    }
+}
