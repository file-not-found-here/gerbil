+import org.springframework.http.ResponseEntity;
+import org.springframework.test.context.ActiveProfiles;
+
+/**
+ * Integration tests for BulletinController.
+ * POST   /api/bulletin        - add bulletin
+ * PUT    /api/bulletin        - modify bulletin
+ * GET    /api/bulletin/{id}   - get by ID
+ * GET    /api/bulletin        - list bulletins
+ * DELETE /api/bulletin        - delete bulletins
+ * GET    /api/bulletin/metrics - get metrics for bulletin
+ */
+@SpringBootTest(webEnvironment = SpringBootTest.WebEnvironment.RANDOM_PORT)
+@ActiveProfiles("test")
+class BulletinControllerTest {
+
+    @Autowired
+    private TestRestTemplate restTemplate;
+
+    private TestRestTemplate admin() {
+        return restTemplate.withBasicAuth("admin", "hertzbeat");
+    }
+
+    private Map<String, Object> buildBulletin(String name) {
+        Map<String, Object> bulletin = new HashMap<>();
+        bulletin.put("name", name);
+        bulletin.put("app", "website");
+        bulletin.put("monitorIds", Arrays.asList(999999999L));
+        Map<String, Object> fields = new HashMap<>();
+        fields.put("summary", Arrays.asList("responseTime", "status"));
+        bulletin.put("fields", fields);
+        return bulletin;
+    }
+
+    @Test
+    void addBulletin_success() {
+        ResponseEntity<Map> response = admin().postForEntity(
+                "/api/bulletin", buildBulletin("test-bulletin-add"), Map.class);
+
+        assertThat(response.getStatusCode()).isEqualTo(HttpStatus.OK);
+        assertThat(response.getBody()).isNotNull();
+        assertThat(((Number) response.getBody().get("code")).intValue()).isZero();
+    }
+
+    @Test
+    void listBulletins_returnsPage() {
+        ResponseEntity<Map> response = admin().getForEntity("/api/bulletin", Map.class);
+
+        assertThat(response.getStatusCode()).isEqualTo(HttpStatus.OK);
+        assertThat(((Number) response.getBody().get("code")).intValue()).isZero();
+        @SuppressWarnings("unchecked")
+        Map<String, Object> data = (Map<String, Object>) response.getBody().get("data");
+        assertThat(data).containsKey("content");
+    }
+
+    @Test
+    void listBulletins_withSearchFilter() {
+        ResponseEntity<Map> response = admin().getForEntity(
+                "/api/bulletin?search=test&pageIndex=0&pageSize=5", Map.class);
+
+        assertThat(response.getStatusCode()).isEqualTo(HttpStatus.OK);
+        assertThat(((Number) response.getBody().get("code")).intValue()).isZero();
+    }
+
+    @Test
+    void getBulletin_nonExistentId_returnsNullData() {
+        ResponseEntity<Map> response = admin().getForEntity(
+                "/api/bulletin/999999999", Map.class);
+
+        assertThat(response.getStatusCode()).isEqualTo(HttpStatus.OK);
+        assertThat(response.getBody()).isNotNull();
+        // controller wraps Optional.empty() as Message.success(null): code=0, data=null
+        assertThat(((Number) response.getBody().get("code")).intValue()).isZero();
+        assertThat(response.getBody().get("data")).isNull();
+    }
+
+    @Test
+    void addAndGetBulletin_success() {
+        String name = "test-bulletin-get";
+        admin().postForEntity("/api/bulletin", buildBulletin(name), Map.class);
+
+        ResponseEntity<Map> listResponse = admin().getForEntity(
+                "/api/bulletin?pageIndex=0&pageSize=100", Map.class);
+        @SuppressWarnings("unchecked")
+        Map<String, Object> pageData = (Map<String, Object>) listResponse.getBody().get("data");
+        @SuppressWarnings("unchecked")
+        List<Map<String, Object>> content = (List<Map<String, Object>>) pageData.get("content");
+
+        content.stream()
+                .filter(b -> name.equals(b.get("name")))
+                .findFirst()
+                .ifPresent(bulletin -> {
+                    Number bulletinId = (Number) bulletin.get("id");
+
+                    ResponseEntity<Map> getResponse = admin().getForEntity(
+                            "/api/bulletin/" + bulletinId.longValue(), Map.class);
+                    assertThat(getResponse.getStatusCode()).isEqualTo(HttpStatus.OK);
+                    assertThat(((Number) getResponse.getBody().get("code")).intValue()).isZero();
+                });
+    }
+
+    @Test
+    void addAndModifyBulletin_success() {
+        String name = "test-bulletin-modify";
+        admin().postForEntity("/api/bulletin", buildBulletin(name), Map.class);
+
+        ResponseEntity<Map> listResponse = admin().getForEntity(
+                "/api/bulletin?pageIndex=0&pageSize=100", Map.class);
+        @SuppressWarnings("unchecked")
+        Map<String, Object> pageData = (Map<String, Object>) listResponse.getBody().get("data");
+        @SuppressWarnings("unchecked")
+        List<Map<String, Object>> content = (List<Map<String, Object>>) pageData.get("content");
+
+        content.stream()
+                .filter(b -> name.equals(b.get("name")))
+                .findFirst()
+                .ifPresent(bulletin -> {
+                    Number bulletinId = (Number) bulletin.get("id");
+                    Map<String, Object> modified = buildBulletin("test-bulletin-modified");
+                    modified.put("id", bulletinId.longValue());
+
+                    ResponseEntity<Map> updateResponse = admin().exchange(
+                            "/api/bulletin", HttpMethod.PUT,
+                            new HttpEntity<>(modified), Map.class);
+
+                    assertThat(updateResponse.getStatusCode()).isEqualTo(HttpStatus.OK);
+                    assertThat(((Number) updateResponse.getBody().get("code")).intValue()).isZero();
+                });
+    }
+
+    @Test
+    void deleteBulletins_withNonExistentId_returnsSuccess() {
+        ResponseEntity<Map> response = admin().exchange(
+                "/api/bulletin?ids=9999999991,9999999992",
+                HttpMethod.DELETE, null, Map.class);
+
+        assertThat(response.getStatusCode()).isEqualTo(HttpStatus.OK);
+        assertThat(((Number) response.getBody().get("code")).intValue()).isZero();
+    }
+
+    @Test
+    void getBulletinMetrics_nonExistentId_returnsResponse() {
+        ResponseEntity<Map> response = admin().getForEntity(
+                "/api/bulletin/metrics?id=999999999", Map.class);
+
+        assertThat(response.getStatusCode()).isEqualTo(HttpStatus.OK);
+        assertThat(response.getBody()).isNotNull();
+    }
+}
