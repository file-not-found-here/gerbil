+
+/**
+ * Integration tests for LabelController.
+ * POST /api/label      - add label
+ * PUT  /api/label      - modify label
+ * GET  /api/label      - list labels
+ * DELETE /api/label    - delete labels
+ */
+@SpringBootTest(webEnvironment = SpringBootTest.WebEnvironment.RANDOM_PORT)
+@ActiveProfiles("test")
+class LabelControllerTest {
+
+    @Autowired
+    private TestRestTemplate restTemplate;
+
+    private TestRestTemplate admin() {
+        return restTemplate.withBasicAuth("admin", "hertzbeat");
+    }
+
+    private TestRestTemplate guest() {
+        return restTemplate.withBasicAuth("guest", "hertzbeat");
+    }
+
+    @Test
+    void createLabel_success() {
+        Map<String, Object> label = new HashMap<>();
+        label.put("name", "test-label-create");
+        label.put("tagValue", "v1");
+        label.put("type", 1);
+
+        ResponseEntity<Map> response = admin().postForEntity("/api/label", label, Map.class);
+
+        assertThat(response.getStatusCode()).isEqualTo(HttpStatus.OK);
+        assertThat(((Number) response.getBody().get("code")).intValue()).isZero();
+        assertThat(response.getBody().get("msg")).isEqualTo("Add success");
+    }
+
+    @Test
+    void createLabel_missingName_returnsValidationError() {
+        Map<String, Object> label = new HashMap<>();
+        label.put("tagValue", "v1");
+        label.put("type", 1);
+
+        ResponseEntity<Map> response = admin().postForEntity("/api/label", label, Map.class);
+
+        assertThat(response.getStatusCode().value()).isGreaterThanOrEqualTo(400);
+    }
+
+    @Test
+    void listLabels_returnsPage() {
+        ResponseEntity<Map> response = admin().getForEntity("/api/label", Map.class);
+
+        assertThat(response.getStatusCode()).isEqualTo(HttpStatus.OK);
+        Map<?, ?> body = response.getBody();
+        assertThat(body).isNotNull();
+        assertThat(((Number) body.get("code")).intValue()).isZero();
+        assertThat(body.get("data")).isNotNull();
+    }
+
+    @Test
+    void listLabels_withSearchFilter() {
+        ResponseEntity<Map> response = admin().getForEntity(
+                "/api/label?search=env&pageIndex=0&pageSize=5", Map.class);
+
+        assertThat(response.getStatusCode()).isEqualTo(HttpStatus.OK);
+        assertThat(((Number) response.getBody().get("code")).intValue()).isZero();
+    }
+
+    @Test
+    void listLabelsAsGuest_returnsPage() {
+        ResponseEntity<Map> response = guest().getForEntity("/api/label", Map.class);
+
+        assertThat(response.getStatusCode()).isEqualTo(HttpStatus.OK);
+        assertThat(((Number) response.getBody().get("code")).intValue()).isZero();
+    }
+
+    @Test
+    void createAndModifyLabel_success() {
+        // Create label
+        Map<String, Object> newLabel = new HashMap<>();
+        newLabel.put("name", "test-label-modify");
+        newLabel.put("tagValue", "original");
+        newLabel.put("type", 1);
+
+        admin().postForEntity("/api/label", newLabel, Map.class);
+
+        // Query to get the ID
+        ResponseEntity<Map> listResponse = admin().getForEntity(
+                "/api/label?search=test-label-modify&pageIndex=0&pageSize=10", Map.class);
+
+        assertThat(listResponse.getStatusCode()).isEqualTo(HttpStatus.OK);
+        @SuppressWarnings("unchecked")
+        Map<String, Object> pageData = (Map<String, Object>) listResponse.getBody().get("data");
+        @SuppressWarnings("unchecked")
+        List<Map<String, Object>> content = (List<Map<String, Object>>) pageData.get("content");
+
+        if (content != null && !content.isEmpty()) {
+            Map<String, Object> existingLabel = content.get(0);
+            Number labelId = (Number) existingLabel.get("id");
+
+            // Modify label
+            Map<String, Object> modifiedLabel = new HashMap<>();
+            modifiedLabel.put("id", labelId.longValue());
+            modifiedLabel.put("name", "test-label-modify");
+            modifiedLabel.put("tagValue", "modified");
+            modifiedLabel.put("type", 1);
+
+            ResponseEntity<Map> updateResponse = admin().exchange(
+                    "/api/label", HttpMethod.PUT,
+                    new HttpEntity<>(modifiedLabel), Map.class);
+
+            assertThat(updateResponse.getStatusCode()).isEqualTo(HttpStatus.OK);
+            assertThat(((Number) updateResponse.getBody().get("code")).intValue()).isZero();
+        }
+    }
+
+    @Test
+    void modifyLabel_withoutId_throwsError() {
+        Map<String, Object> label = new HashMap<>();
+        label.put("name", "test-label-no-id");
+        label.put("tagValue", "v1");
+        label.put("type", 1);
+
+        ResponseEntity<Map> response = admin().exchange(
+                "/api/label", HttpMethod.PUT,
+                new HttpEntity<>(label), Map.class);
+
+        // Without ID the service should return a non-zero response code or 4xx HTTP status
+        boolean httpError = response.getStatusCode().value() >= 400;
+        boolean appError = response.getBody() != null
+                && ((Number) response.getBody().get("code")).intValue() != 0;
+        assertThat(httpError || appError).isTrue();
+    }
+
+    @Test
+    void deleteLabels_withEmptyIds_returnsSuccess() {
+        // Delete with empty list should succeed gracefully
+        ResponseEntity<Map> response = admin().exchange(
+                "/api/label?ids=999999999", HttpMethod.DELETE,
+                null, Map.class);
+
+        assertThat(response.getStatusCode()).isEqualTo(HttpStatus.OK);
+        assertThat(((Number) response.getBody().get("code")).intValue()).isZero();
+    }
+
+    @Test
+    void listLabels_paginationDefaults() {
+        ResponseEntity<Map> response = admin().getForEntity("/api/label", Map.class);
+
+        assertThat(response.getStatusCode()).isEqualTo(HttpStatus.OK);
+        @SuppressWarnings("unchecked")
+        Map<String, Object> pageData = (Map<String, Object>) response.getBody().get("data");
+        assertThat(pageData).isNotNull();
+        assertThat(pageData).containsKey("content");
+        assertThat(pageData).containsKey("totalElements");
+    }
+}
