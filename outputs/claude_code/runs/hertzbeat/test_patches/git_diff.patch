+
+/**
+ * Integration tests for PushPrometheusController.
+ * POST /api/push/prometheus/** - receive Prometheus metrics push (public)
+ */
+@SpringBootTest(webEnvironment = SpringBootTest.WebEnvironment.RANDOM_PORT)
+@ActiveProfiles("test")
+class PushControllerTest {
+
+    @Autowired
+    private TestRestTemplate restTemplate;
+
+    @Test
+    void pushPrometheusMetrics_publicEndpoint_returnsResponse() {
+        HttpHeaders headers = new HttpHeaders();
+        headers.setContentType(MediaType.TEXT_PLAIN);
+        String prometheusMetrics = "# HELP test_metric A test metric\n"
+                + "# TYPE test_metric gauge\n"
+                + "test_metric{job=\"test\"} 1.0 1234567890000\n";
+
+        ResponseEntity<String> response = restTemplate.postForEntity(
+                "/api/push/prometheus/job/test", new HttpEntity<>(prometheusMetrics, headers), String.class);
+
+        // Public endpoint should not return 401/403
+        assertThat(response.getStatusCode().value()).isNotEqualTo(401);
+        assertThat(response.getStatusCode().value()).isNotEqualTo(403);
+    }
+
+    @Test
+    void pushPrometheusMetrics_emptyBody_returnsResponse() {
+        HttpHeaders headers = new HttpHeaders();
+        headers.setContentType(MediaType.TEXT_PLAIN);
+
+        ResponseEntity<String> response = restTemplate.postForEntity(
+                "/api/push/prometheus/job/test", new HttpEntity<>("", headers), String.class);
+
+        // Public endpoint, should be accessible
+        assertThat(response.getStatusCode().value()).isNotEqualTo(401);
+        assertThat(response.getStatusCode().value()).isNotEqualTo(403);
+    }
+}
