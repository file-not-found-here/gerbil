+
+/**
+ * Integration tests for StatusPagePublicController (public endpoints, no auth required).
+ * GET /api/status/page/public/org           - query status page org
+ * GET /api/status/page/public/component     - query status page components
+ * GET /api/status/page/public/component/{id}- query status page component by id
+ * GET /api/status/page/public/incident      - query status page incidents
+ */
+@SpringBootTest(webEnvironment = SpringBootTest.WebEnvironment.RANDOM_PORT)
+@ActiveProfiles("test")
+class StatusPagePublicControllerTest {
+
+    @Autowired
+    private TestRestTemplate restTemplate;
+
+    @Test
+    void queryPublicOrg_noAuth_returnsResponse() {
+        ResponseEntity<Map> response = restTemplate.getForEntity(
+                "/api/status/page/public/org", Map.class);
+
+        // code may be non-zero if no org is configured yet; just check endpoint is reachable
+        assertThat(response.getStatusCode()).isEqualTo(HttpStatus.OK);
+        assertThat(response.getBody()).isNotNull();
+    }
+
+    @Test
+    void queryPublicComponents_noAuth_returnsResponse() {
+        ResponseEntity<Map> response = restTemplate.getForEntity(
+                "/api/status/page/public/component", Map.class);
+
+        assertThat(response.getStatusCode()).isEqualTo(HttpStatus.OK);
+        assertThat(response.getBody()).isNotNull();
+        assertThat(((Number) response.getBody().get("code")).intValue()).isZero();
+    }
+
+    @Test
+    void queryPublicComponentById_nonExistent_returnsResponse() {
+        ResponseEntity<Map> response = restTemplate.getForEntity(
+                "/api/status/page/public/component/999999999", Map.class);
+
+        assertThat(response.getStatusCode()).isEqualTo(HttpStatus.OK);
+        assertThat(response.getBody()).isNotNull();
+    }
+
+    @Test
+    void queryPublicIncidents_noAuth_returnsResponse() {
+        ResponseEntity<Map> response = restTemplate.getForEntity(
+                "/api/status/page/public/incident", Map.class);
+
+        assertThat(response.getStatusCode()).isEqualTo(HttpStatus.OK);
+        assertThat(response.getBody()).isNotNull();
+        assertThat(((Number) response.getBody().get("code")).intValue()).isZero();
+    }
+
+    @Test
+    void queryPublicOrg_publicEndpointAccessible() {
+        // These endpoints are in sureness excludedResource, should not require auth
+        ResponseEntity<Map> response = restTemplate.getForEntity(
+                "/api/status/page/public/org", Map.class);
+
