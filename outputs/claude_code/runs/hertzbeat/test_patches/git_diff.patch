+/**
+ * Integration tests for AlertSilenceController and AlertSilencesController.
+ * POST   /api/alert/silence        - add alert silence
+ * PUT    /api/alert/silence        - modify alert silence
+ * GET    /api/alert/silence/{id}   - get by ID
+ * GET    /api/alert/silences       - list alert silences
+ * DELETE /api/alert/silences       - batch delete
+ */
+@SpringBootTest(webEnvironment = SpringBootTest.WebEnvironment.RANDOM_PORT)
+@ActiveProfiles("test")
+class AlertSilenceControllerTest {
+
+    @Autowired
+    private TestRestTemplate restTemplate;
+
+    private TestRestTemplate admin() {
+        return restTemplate.withBasicAuth("admin", "hertzbeat");
+    }
+
+    private Map<String, Object> buildSilence(String name) {
+        Map<String, Object> silence = new HashMap<>();
+        silence.put("name", name);
+        silence.put("enable", true);
+        silence.put("matchAll", true);
+        silence.put("type", 0);
+        return silence;
+    }
+
+    @Test
+    void addAlertSilence_success() {
+        Map<String, Object> silence = buildSilence("test-silence-add");
+
+        ResponseEntity<Map> response = admin().postForEntity("/api/alert/silence", silence, Map.class);
+
+        assertThat(response.getStatusCode()).isEqualTo(HttpStatus.OK);
+        assertThat(((Number) response.getBody().get("code")).intValue()).isZero();
+    }
+
+    @Test
+    void addAlertSilence_missingName_returnsValidationError() {
+        Map<String, Object> silence = new HashMap<>();
+        silence.put("enable", true);
+        silence.put("type", 0);
+
+        ResponseEntity<Map> response = admin().postForEntity("/api/alert/silence", silence, Map.class);
+
+        assertThat(response.getStatusCode().value()).isGreaterThanOrEqualTo(400);
+    }
+
+    @Test
+    void getAlertSilence_nonExistentId_returnsNotExistCode() {
+        ResponseEntity<Map> response = admin().getForEntity(
+                "/api/alert/silence/999999999", Map.class);
+
+        assertThat(response.getStatusCode()).isEqualTo(HttpStatus.OK);
+        assertThat(((Number) response.getBody().get("code")).intValue()).isNotZero();
+    }
+
+    @Test
+    void addAndGetAlertSilence_success() {
+        String name = "test-silence-get";
+        admin().postForEntity("/api/alert/silence", buildSilence(name), Map.class);
+
+        ResponseEntity<Map> listResponse = admin().getForEntity(
+                "/api/alert/silences?search=" + name + "&pageIndex=0&pageSize=10", Map.class);
+        assertThat(listResponse.getStatusCode()).isEqualTo(HttpStatus.OK);
+        @SuppressWarnings("unchecked")
+        Map<String, Object> pageData = (Map<String, Object>) listResponse.getBody().get("data");
+        @SuppressWarnings("unchecked")
+        List<Map<String, Object>> content = (List<Map<String, Object>>) pageData.get("content");
+
+        if (content != null && !content.isEmpty()) {
+            Number silenceId = (Number) content.get(0).get("id");
+
+            ResponseEntity<Map> getResponse = admin().getForEntity(
+                    "/api/alert/silence/" + silenceId.longValue(), Map.class);
+
+            assertThat(getResponse.getStatusCode()).isEqualTo(HttpStatus.OK);
+            assertThat(((Number) getResponse.getBody().get("code")).intValue()).isZero();
+        }
+    }
+
+    @Test
+    void addAndModifyAlertSilence_success() {
+        String name = "test-silence-modify-orig";
+        admin().postForEntity("/api/alert/silence", buildSilence(name), Map.class);
+
+        ResponseEntity<Map> listResponse = admin().getForEntity(
+                "/api/alert/silences?search=" + name + "&pageIndex=0&pageSize=10", Map.class);
+        @SuppressWarnings("unchecked")
+        Map<String, Object> pageData = (Map<String, Object>) listResponse.getBody().get("data");
+        @SuppressWarnings("unchecked")
+        List<Map<String, Object>> content = (List<Map<String, Object>>) pageData.get("content");
+
+        if (content != null && !content.isEmpty()) {
+            Number silenceId = (Number) content.get(0).get("id");
+            Map<String, Object> modified = buildSilence("test-silence-modify-new");
+            modified.put("id", silenceId.longValue());
+
+            ResponseEntity<Map> updateResponse = admin().exchange(
+                    "/api/alert/silence", HttpMethod.PUT,
+                    new HttpEntity<>(modified), Map.class);
+
+            assertThat(updateResponse.getStatusCode()).isEqualTo(HttpStatus.OK);
+            assertThat(((Number) updateResponse.getBody().get("code")).intValue()).isZero();
+        }
+    }
+
+    // AlertSilencesController tests
+
+    @Test
+    void listAlertSilences_returnsPage() {
+        ResponseEntity<Map> response = admin().getForEntity("/api/alert/silences", Map.class);
+
+        assertThat(response.getStatusCode()).isEqualTo(HttpStatus.OK);
+        assertThat(((Number) response.getBody().get("code")).intValue()).isZero();
+        @SuppressWarnings("unchecked")
+        Map<String, Object> data = (Map<String, Object>) response.getBody().get("data");
+        assertThat(data).containsKey("content");
+        assertThat(data).containsKey("totalElements");
+    }
+
+    @Test
+    void listAlertSilences_withFilters() {
+        ResponseEntity<Map> response = admin().getForEntity(
+                "/api/alert/silences?sort=id&order=desc&pageIndex=0&pageSize=5", Map.class);
+
+        assertThat(response.getStatusCode()).isEqualTo(HttpStatus.OK);
+        assertThat(((Number) response.getBody().get("code")).intValue()).isZero();
+    }
+
+    @Test
+    void batchDeleteAlertSilences_withNonExistentIds_returnsSuccess() {
+        ResponseEntity<Map> response = admin().exchange(
+                "/api/alert/silences?ids=9999999991,9999999992",
+                HttpMethod.DELETE, null, Map.class);
+
+        assertThat(response.getStatusCode()).isEqualTo(HttpStatus.OK);
+        assertThat(((Number) response.getBody().get("code")).intValue()).isZero();
+    }
+}
