+/**
+ * Integration tests for AlertDefineController and AlertDefinesController.
+ * POST   /api/alert/define        - add alert definition
+ * PUT    /api/alert/define        - modify alert definition
+ * GET    /api/alert/define/{id}   - get by ID
+ * DELETE /api/alert/define/{id}   - delete
+ * GET    /api/alert/defines       - list alert definitions
+ * DELETE /api/alert/defines       - batch delete
+ */
+@SpringBootTest(webEnvironment = SpringBootTest.WebEnvironment.RANDOM_PORT)
+@ActiveProfiles("test")
+class AlertDefineControllerTest {
+
+    @Autowired
+    private TestRestTemplate restTemplate;
+
+    private TestRestTemplate admin() {
+        return restTemplate.withBasicAuth("admin", "hertzbeat");
+    }
+
+    private TestRestTemplate guest() {
+        return restTemplate.withBasicAuth("guest", "hertzbeat");
+    }
+
+    private Map<String, Object> buildAlertDefine(String name) {
+        Map<String, Object> define = new HashMap<>();
+        define.put("name", name);
+        define.put("expr", "usage > 90");
+        define.put("type", "realtime");
+        define.put("times", 3);
+        define.put("enable", true);
+        return define;
+    }
+
+    @Test
+    void addAlertDefine_success() {
+        Map<String, Object> define = buildAlertDefine("test-alert-add");
+
+        ResponseEntity<Map> response = admin().postForEntity(
+                "/api/alert/define", define, Map.class);
+
+        assertThat(response.getStatusCode()).isEqualTo(HttpStatus.OK);
+        assertThat(((Number) response.getBody().get("code")).intValue()).isZero();
+        assertThat(response.getBody().get("msg")).isEqualTo("Add success");
+    }
+
+    @Test
+    void addAlertDefine_missingName_returnsValidationError() {
+        Map<String, Object> define = new HashMap<>();
+        define.put("expr", "usage > 90");
+        define.put("type", "realtime");
+
+        ResponseEntity<Map> response = admin().postForEntity(
+                "/api/alert/define", define, Map.class);
+
+        assertThat(response.getStatusCode().value()).isGreaterThanOrEqualTo(400);
+    }
+
+    @Test
+    void getAlertDefine_nonExistentId_returnsNotExistCode() {
+        ResponseEntity<Map> response = admin().getForEntity(
+                "/api/alert/define/999999999", Map.class);
+
+        assertThat(response.getStatusCode()).isEqualTo(HttpStatus.OK);
+        // MONITOR_NOT_EXIST_CODE = 3
+        assertThat(((Number) response.getBody().get("code")).intValue()).isEqualTo(3);
+    }
+
+    @Test
+    void addAndGetAlertDefine_success() {
+        String name = "test-alert-get";
+        admin().postForEntity("/api/alert/define", buildAlertDefine(name), Map.class);
+
+        // List all defines and find by name (search param requires JSON array format)
+        ResponseEntity<Map> listResponse = admin().getForEntity(
+                "/api/alert/defines?pageIndex=0&pageSize=100", Map.class);
+        assertThat(listResponse.getStatusCode()).isEqualTo(HttpStatus.OK);
+        @SuppressWarnings("unchecked")
+        Map<String, Object> pageData = (Map<String, Object>) listResponse.getBody().get("data");
+        @SuppressWarnings("unchecked")
+        java.util.List<Map<String, Object>> content =
+                (java.util.List<Map<String, Object>>) pageData.get("content");
+
+        java.util.Optional<Map<String, Object>> found = content.stream()
+                .filter(d -> name.equals(d.get("name"))).findFirst();
+        if (found.isPresent()) {
+            Number defineId = (Number) found.get().get("id");
+
+            ResponseEntity<Map> getResponse = admin().getForEntity(
+                    "/api/alert/define/" + defineId.longValue(), Map.class);
+
+            assertThat(getResponse.getStatusCode()).isEqualTo(HttpStatus.OK);
+            assertThat(((Number) getResponse.getBody().get("code")).intValue()).isZero();
