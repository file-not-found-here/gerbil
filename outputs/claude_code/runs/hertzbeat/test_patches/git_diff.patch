+package org.apache.hertzbeat.manager.controller;
+
+import static org.assertj.core.api.Assertions.assertThat;
+
+import java.util.Map;
+import org.junit.jupiter.api.Test;
+import org.springframework.beans.factory.annotation.Autowired;
+import org.springframework.boot.test.context.SpringBootTest;
+import org.springframework.boot.test.web.client.TestRestTemplate;
+import org.springframework.http.HttpStatus;
+import org.springframework.http.ResponseEntity;
+import org.springframework.test.context.ActiveProfiles;
+
+/**
+ * Integration tests for AccountController.
+ * POST /api/account/auth/form  - login (public)
+ * POST /api/account/auth/refresh - refresh token (public)
+ */
+@SpringBootTest(webEnvironment = SpringBootTest.WebEnvironment.RANDOM_PORT)
+@ActiveProfiles("test")
+class AccountControllerTest {
+
+    @Autowired
+    private TestRestTemplate restTemplate;
+
+    @Test
+    void loginWithValidCredentials_returnsTokens() {
+        Map<String, Object> body = Map.of(
+                "identifier", "admin",
+                "credential", "hertzbeat",
+                "type", 0
+        );
+
+        ResponseEntity<Map> response = restTemplate.postForEntity(
+                "/api/account/auth/form", body, Map.class);
+
+        assertThat(response.getStatusCode()).isEqualTo(HttpStatus.OK);
+        Map<?, ?> responseBody = response.getBody();
+        assertThat(responseBody).isNotNull();
+        // SUCCESS_CODE = 0
+        assertThat(((Number) responseBody.get("code")).intValue()).isZero();
+        @SuppressWarnings("unchecked")
+        Map<String, String> data = (Map<String, String>) responseBody.get("data");
+        assertThat(data).isNotNull();
+        assertThat(data).containsKey("token");
+        assertThat(data).containsKey("refreshToken");
+    }
+
+    @Test
+    void loginWithWrongPassword_returnsLoginFailedCode() {
+        Map<String, Object> body = Map.of(
+                "identifier", "admin",
+                "credential", "wrong-password",
+                "type", 0
+        );
+
+        ResponseEntity<Map> response = restTemplate.postForEntity(
+                "/api/account/auth/form", body, Map.class);
+
+        assertThat(response.getStatusCode()).isEqualTo(HttpStatus.OK);
+        Map<?, ?> responseBody = response.getBody();
+        assertThat(responseBody).isNotNull();
+        // LOGIN_FAILED_CODE = 5
+        assertThat(((Number) responseBody.get("code")).intValue()).isEqualTo(5);
+    }
+
+    @Test
+    void loginWithMissingIdentifier_returns4xxOrValidationError() {
+        Map<String, Object> body = Map.of(
+                "credential", "hertzbeat",
+                "type", 0
+        );
+
+        ResponseEntity<Map> response = restTemplate.postForEntity(
+                "/api/account/auth/form", body, Map.class);
+
+        // Bean validation failure returns 400
+        assertThat(response.getStatusCode().value()).isGreaterThanOrEqualTo(400);
+    }
+
+    @Test
+    void loginWithMissingCredential_returns4xxOrValidationError() {
+        Map<String, Object> body = Map.of(
+                "identifier", "admin",
+                "type", 0
+        );
+
+        ResponseEntity<Map> response = restTemplate.postForEntity(
+                "/api/account/auth/form", body, Map.class);
+
+        assertThat(response.getStatusCode().value()).isGreaterThanOrEqualTo(400);
+    }
+
+    @Test
+    void refreshTokenWithValidToken_returnsNewTokens() {
+        // First login to obtain tokens
+        Map<String, Object> loginBody = Map.of(
+                "identifier", "admin",
+                "credential", "hertzbeat",
+                "type", 0
+        );
+        ResponseEntity<Map> loginResponse = restTemplate.postForEntity(
+                "/api/account/auth/form", loginBody, Map.class);
+        @SuppressWarnings("unchecked")
+        Map<String, String> loginData = (Map<String, String>) loginResponse.getBody().get("data");
+        String refreshToken = loginData.get("refreshToken");
+
+        // Now refresh
+        Map<String, Object> refreshBody = Map.of("token", refreshToken);
+        ResponseEntity<Map> response = restTemplate.postForEntity(
+                "/api/account/auth/refresh", refreshBody, Map.class);
+
+        assertThat(response.getStatusCode()).isEqualTo(HttpStatus.OK);
+        Map<?, ?> responseBody = response.getBody();
+        assertThat(responseBody).isNotNull();
+        assertThat(((Number) responseBody.get("code")).intValue()).isZero();
+    }
+
+    @Test
+    void refreshTokenWithInvalidToken_returnsLoginFailedCode() {
+        Map<String, Object> refreshBody = Map.of("token", "invalid.token.value");
+        ResponseEntity<Map> response = restTemplate.postForEntity(
+                "/api/account/auth/refresh", refreshBody, Map.class);
+
+        assertThat(response.getStatusCode()).isEqualTo(HttpStatus.OK);
+        assertThat(((Number) response.getBody().get("code")).intValue()).isEqualTo(5);
+    }
+}
