+package org.apache.hertzbeat.manager.controller;
+
+import static org.assertj.core.api.Assertions.assertThat;
+
+import java.util.Map;
+import org.junit.jupiter.api.Test;
+import org.springframework.beans.factory.annotation.Autowired;
+import org.springframework.boot.test.context.SpringBootTest;
+import org.springframework.boot.test.web.client.TestRestTemplate;
+import org.springframework.core.io.Resource;
+import org.springframework.http.ResponseEntity;
+import org.springframework.test.context.ActiveProfiles;
+
+/**
+ * Integration tests for AlertDefinesController export/import endpoints.
+ * GET  /api/alert/defines/export  - export alert definitions (JSON/EXCEL/YAML)
+ * POST /api/alert/defines/import  - import alert definitions from file
+ */
+@SpringBootTest(webEnvironment = SpringBootTest.WebEnvironment.RANDOM_PORT)
+@ActiveProfiles("test")
+class AlertDefineExportControllerTest {
+
+    @Autowired
+    private TestRestTemplate restTemplate;
+
+    private TestRestTemplate admin() {
+        return restTemplate.withBasicAuth("admin", "hertzbeat");
+    }
+
+    @Test
+    void exportAlertDefines_asJson_withNoIds_returnsFile() {
+        ResponseEntity<Resource> response = admin().getForEntity(
+                "/api/alert/defines/export?ids=&type=JSON", Resource.class);
+
+        // With empty/no ids the export should succeed or return a bad request
+        assertThat(response.getStatusCode().value()).isNotEqualTo(401);
+        assertThat(response.getStatusCode().value()).isNotEqualTo(403);
+    }
+
+    @Test
+    void exportAlertDefines_withNonExistentIds_returnsResponse() {
+        // First add an alert define so we have a valid ID scenario
+        Map<String, Object> define = new java.util.HashMap<>();
+        define.put("name", "test-export-define");
+        define.put("expr", "metric > 90");
+        define.put("type", "realtime");
+        define.put("times", 1);
+        define.put("enable", true);
+        admin().postForEntity("/api/alert/define", define, Map.class);
+
+        // Export with non-existent IDs - should still return a response
+        ResponseEntity<Resource> response = admin().getForEntity(
+                "/api/alert/defines/export?ids=9999999991&type=JSON", Resource.class);
+
+        // Export succeeds (possibly empty file) or returns error, but not auth error
+        assertThat(response.getStatusCode().value()).isNotEqualTo(401);
+        assertThat(response.getStatusCode().value()).isNotEqualTo(403);
+    }
+
+    @Test
+    void exportAlertDefines_withoutAuth_returnsUnauthorized() {
+        ResponseEntity<Resource> response = restTemplate.getForEntity(
+                "/api/alert/defines/export?ids=1&type=JSON", Resource.class);
+
+        assertThat(response.getStatusCode().value()).isGreaterThanOrEqualTo(400);
+    }
+}
