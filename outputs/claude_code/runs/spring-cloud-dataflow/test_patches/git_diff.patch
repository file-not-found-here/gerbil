+package org.springframework.cloud.dataflow.server.controller;
+
+import java.util.Collections;
+import java.util.Date;
+
+import org.junit.jupiter.api.BeforeEach;
+import org.mockito.Mockito;
+
+import org.springframework.beans.factory.annotation.Autowired;
+import org.springframework.boot.test.autoconfigure.web.servlet.AutoConfigureMockMvc;
+import org.springframework.boot.test.context.SpringBootTest;
+import org.springframework.boot.test.mock.mockito.MockBean;
+import org.springframework.cloud.dataflow.audit.service.AuditRecordService;
+import org.springframework.cloud.dataflow.completion.StreamCompletionProvider;
+import org.springframework.cloud.dataflow.completion.TaskCompletionProvider;
+import org.springframework.cloud.dataflow.configuration.metadata.ApplicationConfigurationMetadataResolver;
+import org.springframework.cloud.dataflow.core.StreamDefinitionService;
+import org.springframework.cloud.dataflow.registry.service.AppRegistryService;
+import org.springframework.cloud.dataflow.registry.support.AppResourceCommon;
+import org.springframework.cloud.dataflow.rest.job.TaskJobExecution;
+import org.springframework.cloud.dataflow.server.test.TestApplication;
+import org.springframework.cloud.dataflow.server.batch.JdbcSearchableJobExecutionDao;
+import org.springframework.cloud.dataflow.server.batch.JobService;
+import org.springframework.cloud.dataflow.server.service.TaskDeleteService;
+import org.springframework.cloud.dataflow.server.service.TaskExecutionInfoService;
+import org.springframework.cloud.dataflow.server.service.TaskExecutionService;
+import org.springframework.cloud.dataflow.server.service.TaskJobService;
+import org.springframework.cloud.dataflow.server.service.TaskSaveService;
+import org.springframework.cloud.dataflow.server.service.StreamService;
+import org.springframework.cloud.dataflow.server.stream.SkipperStreamDeployer;
+import org.springframework.cloud.dataflow.server.task.DataflowTaskExplorer;
+import org.springframework.data.domain.PageImpl;
+import org.springframework.data.domain.Pageable;
+import org.springframework.test.web.servlet.MockMvc;
+import org.springframework.web.client.ResourceAccessException;
+
+import static org.mockito.ArgumentMatchers.any;
+import static org.mockito.ArgumentMatchers.anyBoolean;
+import static org.mockito.ArgumentMatchers.anyInt;
+import static org.mockito.ArgumentMatchers.anyLong;
+import static org.mockito.ArgumentMatchers.anyString;
+import static org.mockito.BDDMockito.given;
+import static org.mockito.BDDMockito.willThrow;
+
+/**
+ * Abstract base class for controller integration tests. Provides a shared Spring
+ * application context with mocked service dependencies so tests can focus on
+ * HTTP-level behaviour without needing a real Skipper server or task launchers.
+ */
+@SpringBootTest(classes = TestApplication.class,
+		webEnvironment = SpringBootTest.WebEnvironment.MOCK)
+@AutoConfigureMockMvc
+public abstract class AbstractControllerTests {
+
+	@Autowired
+	protected MockMvc mockMvc;
+
+	// ---- Application registry ----
+	@MockBean
+	protected AppRegistryService appRegistryService;
+
+	@MockBean
+	protected ApplicationConfigurationMetadataResolver metadataResolver;
+
+	@MockBean
+	protected AppResourceCommon appResourceCommon;
+
+	// ---- Stream / completion ----
+	@MockBean
+	protected StreamCompletionProvider streamCompletionProvider;
+
+	@MockBean
+	protected TaskCompletionProvider taskCompletionProvider;
+
+	@MockBean
+	protected StreamDefinitionService streamDefinitionService;
+
+	@MockBean
+	protected StreamService streamService;
+
+	@MockBean
+	protected SkipperStreamDeployer skipperStreamDeployer;
+
+	// ---- Audit ----
+	@MockBean
+	protected AuditRecordService auditRecordService;
+
+	// ---- Task services ----
+	@MockBean
+	protected TaskExecutionService taskExecutionService;
+
+	@MockBean
+	protected TaskDeleteService taskDeleteService;
+
+	@MockBean
+	protected TaskSaveService taskSaveService;
+
+	@MockBean
+	protected TaskJobService taskJobService;
+
+	@MockBean
+	protected DataflowTaskExplorer dataflowTaskExplorer;
+
+	@MockBean
+	protected TaskExecutionInfoService taskExecutionInfoService;
+
+	// ---- Batch ----
+	@MockBean
+	protected JobService jobService;
+
+	@MockBean
+	protected JdbcSearchableJobExecutionDao jdbcSearchableJobExecutionDao;
+
+	@BeforeEach
+	void setUpBase() throws Exception {
+		Mockito.reset(
+				appRegistryService, metadataResolver, appResourceCommon,
+				streamCompletionProvider, taskCompletionProvider,
+				streamDefinitionService, streamService, skipperStreamDeployer,
+				auditRecordService, taskExecutionService, taskDeleteService,
+				taskSaveService, taskJobService, dataflowTaskExplorer,
+				taskExecutionInfoService, jobService, jdbcSearchableJobExecutionDao
+		);
+
+		// AboutController calls streamDeployer.environmentInfo(); the catch block
+		// handles ResourceAccessException gracefully so no NPE on null result.
+		willThrow(new ResourceAccessException("Skipper not available in tests"))
+				.given(skipperStreamDeployer).environmentInfo();
+
+		// Completion providers return empty lists by default
+		given(streamCompletionProvider.complete(any(), anyInt())).willReturn(Collections.emptyList());
+		given(taskCompletionProvider.complete(any(), anyInt())).willReturn(Collections.emptyList());
+
+		// Stream service state - prevents NPE in stream definition assembler
+		given(streamService.state(any())).willReturn(Collections.emptyMap());
+
+		// Common service list defaults - prevent NPE when mocks return null for Page results
+		given(auditRecordService.findAuditRecordByAuditOperationTypeAndAuditActionTypeAndDate(
+				any(Pageable.class), any(), any(), any(), any()))
+				.willReturn(new PageImpl<>(Collections.emptyList()));
+
+		given(appRegistryService.findAllByTypeAndNameIsLikeAndVersionAndDefaultVersion(
+				any(), any(), any(), anyBoolean(), any(Pageable.class)))
+				.willReturn(new PageImpl<>(Collections.emptyList()));
+
+		given(streamService.findDefinitionByNameContains(any(Pageable.class), any()))
+				.willReturn(new PageImpl<>(Collections.emptyList()));
+
+		given(dataflowTaskExplorer.findAll(any(Pageable.class)))
+				.willReturn(new PageImpl<>(Collections.emptyList()));
+
+		given(taskJobService.listJobExecutions(any(Pageable.class)))
+				.willReturn(new PageImpl<>(Collections.emptyList()));
+
+		given(taskJobService.listJobExecutionsWithStepCount(any(Pageable.class)))
+				.willReturn(new PageImpl<>(Collections.emptyList()));
+
+		given(taskJobService.listJobExecutionsForJobWithStepCount(any(Pageable.class), anyString()))
+				.willReturn(new PageImpl<>(Collections.emptyList()));
+
+		given(taskJobService.listJobExecutionsForJobWithStepCount(any(Pageable.class), any(Date.class), any(Date.class)))
+				.willReturn(new PageImpl<>(Collections.emptyList()));
+
+		given(taskJobService.listJobExecutionsForJobWithStepCountFilteredByJobInstanceId(any(Pageable.class), anyInt()))
+				.willReturn(new PageImpl<>(Collections.emptyList()));
+
+		given(taskJobService.listJobExecutionsForJobWithStepCountFilteredByTaskExecutionId(any(Pageable.class), anyInt()))
+				.willReturn(new PageImpl<>(Collections.emptyList()));
+
+		given(taskJobService.listTaskJobInstancesForJobName(any(Pageable.class), anyString()))
+				.willReturn(new PageImpl<>(Collections.emptyList()));
+
+		given(jobService.getStepExecutions(anyLong()))
+				.willReturn(Collections.emptyList());
+
+		given(taskJobService.listJobExecutionsForJob(any(Pageable.class), anyString(), any()))
+				.willReturn(new PageImpl<>(Collections.emptyList()));
+	}
+}
