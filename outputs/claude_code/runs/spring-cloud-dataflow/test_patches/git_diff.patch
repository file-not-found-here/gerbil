+package org.springframework.cloud.dataflow.server.controller;
+
+import org.junit.jupiter.api.Test;
+
+import static org.springframework.test.web.servlet.request.MockMvcRequestBuilders.get;
+import static org.springframework.test.web.servlet.result.MockMvcResultMatchers.jsonPath;
+import static org.springframework.test.web.servlet.result.MockMvcResultMatchers.status;
+
+/**
+ * Integration tests for {@link AboutController}.
+ */
+class AboutControllerTests extends AbstractControllerTests {
+
+	@Test
+	void aboutReturns200() throws Exception {
+		mockMvc.perform(get("/about"))
+				.andExpect(status().isOk());
+	}
+
+	@Test
+	void aboutContainsFeatureInfo() throws Exception {
+		mockMvc.perform(get("/about"))
+				.andExpect(status().isOk())
+				.andExpect(jsonPath("$.featureInfo").exists())
+				.andExpect(jsonPath("$.featureInfo.tasksEnabled").value(true))
+				.andExpect(jsonPath("$.featureInfo.streamsEnabled").value(true))
+				.andExpect(jsonPath("$.featureInfo.schedulesEnabled").value(false));
+	}
+
+	@Test
+	void aboutContainsVersionInfo() throws Exception {
+		mockMvc.perform(get("/about"))
+				.andExpect(status().isOk())
+				.andExpect(jsonPath("$.versionInfo").exists());
+	}
+
+	@Test
+	void aboutContainsSecurityInfo() throws Exception {
+		mockMvc.perform(get("/about"))
+				.andExpect(status().isOk())
+				.andExpect(jsonPath("$.securityInfo").exists())
+				.andExpect(jsonPath("$.securityInfo.authenticationEnabled").value(false));
+	}
+
+	@Test
+	void aboutContainsRuntimeEnvironment() throws Exception {
+		mockMvc.perform(get("/about"))
+				.andExpect(status().isOk())
+				.andExpect(jsonPath("$.runtimeEnvironment").exists());
+	}
+
+	@Test
+	void aboutContainsSelfLink() throws Exception {
+		mockMvc.perform(get("/about"))
+				.andExpect(status().isOk())
+				.andExpect(jsonPath("$._links.self.href").exists());
+	}
+}
