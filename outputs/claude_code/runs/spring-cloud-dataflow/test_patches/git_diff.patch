+/**
+ * Integration tests for {@link AppRegistryController}.
+ */
+class AppRegistryControllerTests extends AbstractControllerTests {
+
+	@Test
+	void listAppsReturns200() throws Exception {
+		mockMvc.perform(get("/apps"))
+				.andExpect(status().isOk());
+	}
+
+	@Test
+	void listAppsContainsPageMetadata() throws Exception {
+		mockMvc.perform(get("/apps"))
+				.andExpect(status().isOk())
+				.andExpect(jsonPath("$.page").exists());
+	}
+
+	@Test
+	void listAppsFilteredByTypeReturns200() throws Exception {
+		mockMvc.perform(get("/apps").param("type", "source"))
+				.andExpect(status().isOk());
+	}
+
+	@Test
+	void listAppsFilteredBySearchReturns200() throws Exception {
+		mockMvc.perform(get("/apps").param("search", "time"))
+				.andExpect(status().isOk());
+	}
+
+	@Test
+	void getAppInfoByVersionReturns404WhenNotFound() throws Exception {
+		given(appRegistryService.find(anyString(), any(ApplicationType.class), anyString()))
+				.willReturn(null);
+
+		mockMvc.perform(get("/apps/source/nonexistent/1.0.0"))
+				.andExpect(status().isNotFound());
+	}
+
+	@Test
+	void getAppInfoDefaultVersionReturns404WhenNotFound() throws Exception {
+		given(appRegistryService.appExist(anyString(), any(ApplicationType.class))).willReturn(false);
+
+		mockMvc.perform(get("/apps/source/nonexistent"))
+				.andExpect(status().isNotFound());
+	}
+
+	@Test
+	void deleteAllAppsReturns200() throws Exception {
+		given(appRegistryService.findAll()).willReturn(Collections.emptyList());
+
+		mockMvc.perform(delete("/apps"))
+				.andExpect(status().isOk());
+	}
+
+	@Test
+	void registerAppByVersionReturns201() throws Exception {
+		mockMvc.perform(post("/apps/source/myapp/1.0.0")
+						.param("uri", "maven://io.spring:time-source:3.0.0"))
+				.andExpect(status().isCreated());
+	}
+
+	@Test
+	void registerAppAutoDetectVersionReturns201() throws Exception {
+		given(appRegistryService.getResourceVersion(anyString())).willReturn("1.0.0");
+
+		mockMvc.perform(post("/apps/source/myapp")
+						.param("uri", "maven://io.spring:time-source:3.0.0"))
+				.andExpect(status().isCreated());
+	}
+
+	@Test
+	void setDefaultAppVersionReturns202() throws Exception {
+		mockMvc.perform(put("/apps/source/myapp/1.0.0"))
+				.andExpect(status().isAccepted());
+	}
+
+	@Test
+	void unregisterSpecificVersionReturns404WhenNotFound() throws Exception {
+		given(appRegistryService.appExist(anyString(), any(ApplicationType.class), anyString()))
+				.willReturn(false);
+
+		mockMvc.perform(delete("/apps/source/myapp/1.0.0"))
+				.andExpect(status().isNotFound());
+	}
+
+	@Test
+	void unregisterAllVersionsReturns404WhenNotFound() throws Exception {
+		mockMvc.perform(delete("/apps/source/myapp"))
+				.andExpect(status().isNotFound());
+	}
+
+	@Test
+	void bulkImportAppsReturns201() throws Exception {
