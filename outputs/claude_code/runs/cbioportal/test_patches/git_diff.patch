+  private static final long START_TIME = System.currentTimeMillis();
+
+  private ClinicalAttribute createAttr(
+      String attrId, String studyId, String displayName, boolean patientAttribute) {
+    ClinicalAttribute attr = new ClinicalAttribute();
+    attr.setAttrId(attrId);
+    attr.setCancerStudyIdentifier(studyId);
+    attr.setDisplayName(displayName);
+    attr.setDescription("A clinical attribute");
+    attr.setDatatype("STRING");
+    attr.setPatientAttribute(patientAttribute);
+    attr.setPriority("1");
+    return attr;
+  }
+
+  @Test
+  void getAllClinicalAttributes_returnsListWithOk() throws Exception {
+    List<ClinicalAttribute> attrs =
+        Arrays.asList(
+            createAttr("CANCER_TYPE", "acc_tcga", "Cancer Type", false),
+            createAttr("AGE", "acc_tcga", "Age at Diagnosis", true),
