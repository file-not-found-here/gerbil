+import org.springframework.boot.autoconfigure.security.servlet.SecurityAutoConfiguration;
+import org.springframework.boot.autoconfigure.security.servlet.SecurityFilterAutoConfiguration;
+import org.springframework.boot.test.autoconfigure.web.servlet.WebMvcTest;
+import org.springframework.boot.test.mock.mockito.MockBean;
+import org.springframework.context.annotation.Import;
+import org.springframework.http.MediaType;
+import org.springframework.test.web.servlet.MockMvc;
+
+@Import(JacksonConfig.class)
+@WebMvcTest(
+    controllers = ClinicalDataController.class,
+    excludeAutoConfiguration = {
+      SecurityAutoConfiguration.class,
+      SecurityFilterAutoConfiguration.class
+    })
+class ClinicalDataControllerTest {
+
+  @Autowired private MockMvc mockMvc;
+
+  @MockBean private ClinicalDataService clinicalDataService;
+  @MockBean private CacheMapUtil cacheMapUtil;
+
+  private static final long START_TIME = System.currentTimeMillis();
+
+  private ClinicalData createClinicalData(
+      String studyId, String sampleId, String attrId, String attrValue) {
+    ClinicalData data = new ClinicalData();
+    data.setStudyId(studyId);
+    data.setSampleId(sampleId);
+    data.setAttrId(attrId);
+    data.setAttrValue(attrValue);
+    data.setPatientId("TCGA-OR-A5J2");
+    return data;
+  }
+
+  @Test
+  void getAllClinicalDataInStudy_returnsListWithOk() throws Exception {
+    List<ClinicalData> dataList =
+        Arrays.asList(
+            createClinicalData("acc_tcga", "TCGA-OR-A5J2-01", "CANCER_TYPE", "ACC"),
+            createClinicalData("acc_tcga", "TCGA-OR-A5J3-01", "CANCER_TYPE", "ACC"));
+
+    when(clinicalDataService.getAllClinicalDataInStudy(
+            eq("acc_tcga"), any(), any(), any(), anyInt(), anyInt(), any(), any()))
+        .thenReturn(dataList);
+
+    mockMvc
+        .perform(
+            get("/api/studies/acc_tcga/clinical-data")
+                .accept(MediaType.APPLICATION_JSON)
+                .requestAttr("startTime", START_TIME))
+        .andExpect(status().isOk())
+        .andExpect(content().contentTypeCompatibleWith(MediaType.APPLICATION_JSON))
+        .andExpect(jsonPath("$.length()").value(2))
+        .andExpect(jsonPath("$[0].clinicalAttributeId").value("CANCER_TYPE"))
+        .andExpect(jsonPath("$[0].value").value("ACC"))
+        .andExpect(jsonPath("$[0].studyId").value("acc_tcga"));
+  }
+
+  @Test
+  void getAllClinicalDataInStudy_withMetaProjection_returnsTotalCountHeader() throws Exception {
+    BaseMeta meta = new BaseMeta();
