+package org.cbioportal.legacy.web;
+
+import static org.mockito.ArgumentMatchers.*;
+import static org.mockito.Mockito.when;
+import static org.springframework.test.web.servlet.request.MockMvcRequestBuilders.*;
+import static org.springframework.test.web.servlet.result.MockMvcResultMatchers.*;
+
+import java.util.Arrays;
+import java.util.List;
+import org.cbioportal.legacy.model.TypeOfCancer;
+import org.cbioportal.legacy.model.meta.BaseMeta;
+import org.cbioportal.legacy.persistence.cachemaputil.CacheMapUtil;
+import org.cbioportal.legacy.service.CancerTypeService;
+import org.cbioportal.legacy.service.exception.CancerTypeNotFoundException;
+import org.junit.jupiter.api.Test;
+import org.springframework.beans.factory.annotation.Autowired;
+import org.springframework.boot.autoconfigure.security.servlet.SecurityAutoConfiguration;
+import org.springframework.boot.autoconfigure.security.servlet.SecurityFilterAutoConfiguration;
+import org.springframework.boot.test.autoconfigure.web.servlet.WebMvcTest;
+import org.springframework.boot.test.mock.mockito.MockBean;
+import org.springframework.http.MediaType;
+import org.springframework.test.web.servlet.MockMvc;
+
+@WebMvcTest(
+    controllers = CancerTypeController.class,
+    excludeAutoConfiguration = {
+      SecurityAutoConfiguration.class,
+      SecurityFilterAutoConfiguration.class
+    })
+class CancerTypeControllerTest {
+
+  @Autowired private MockMvc mockMvc;
+
+  @MockBean private CancerTypeService cancerTypeService;
+  @MockBean private CacheMapUtil cacheMapUtil;
+
+  private static final long START_TIME = System.currentTimeMillis();
+
+  private TypeOfCancer createCancerType(String id, String name) {
+    TypeOfCancer type = new TypeOfCancer();
+    type.setTypeOfCancerId(id);
+    type.setName(name);
+    type.setDedicatedColor("HotPink");
+    type.setShortName(id.toUpperCase());
+    type.setParent("tissue");
+    return type;
+  }
+
+  @Test
+  void getAllCancerTypes_returnsListWithOk() throws Exception {
+    List<TypeOfCancer> types =
+        Arrays.asList(
+            createCancerType("acc", "Adrenocortical Carcinoma"),
+            createCancerType("blca", "Bladder Urothelial Carcinoma"));
+
+    when(cancerTypeService.getAllCancerTypes(any(), anyInt(), anyInt(), any(), any()))
+        .thenReturn(types);
+
+    mockMvc
+        .perform(
+            get("/api/cancer-types")
+                .accept(MediaType.APPLICATION_JSON)
+                .requestAttr("startTime", START_TIME))
+        .andExpect(status().isOk())
+        .andExpect(content().contentTypeCompatibleWith(MediaType.APPLICATION_JSON))
+        .andExpect(jsonPath("$.length()").value(2))
+        .andExpect(jsonPath("$[0].name").value("Adrenocortical Carcinoma"))
+        .andExpect(jsonPath("$[1].name").value("Bladder Urothelial Carcinoma"));
+  }
+
+  @Test
+  void getAllCancerTypes_withProjectionMeta_returnsTotalCountHeader() throws Exception {
+    BaseMeta meta = new BaseMeta();
+    meta.setTotalCount(42);
+
+    when(cancerTypeService.getMetaCancerTypes()).thenReturn(meta);
+
+    mockMvc
+        .perform(
+            get("/api/cancer-types")
+                .param("projection", "META")
+                .accept(MediaType.APPLICATION_JSON)
+                .requestAttr("startTime", START_TIME))
+        .andExpect(status().isOk())
+        .andExpect(header().string("Total-Count", "42"));
+  }
+
+  @Test
+  void getCancerType_existingId_returnsType() throws Exception {
+    TypeOfCancer acc = createCancerType("acc", "Adrenocortical Carcinoma");
+
+    when(cancerTypeService.getCancerType("acc")).thenReturn(acc);
+
+    mockMvc
+        .perform(
+            get("/api/cancer-types/acc")
+                .accept(MediaType.APPLICATION_JSON)
+                .requestAttr("startTime", START_TIME))
+        .andExpect(status().isOk())
+        .andExpect(content().contentTypeCompatibleWith(MediaType.APPLICATION_JSON))
+        .andExpect(jsonPath("$.name").value("Adrenocortical Carcinoma"));
+  }
+
+  @Test
+  void getCancerType_nonExistentId_returns404() throws Exception {
+    when(cancerTypeService.getCancerType("nonexistent"))
+        .thenThrow(new CancerTypeNotFoundException("nonexistent"));
+
+    mockMvc
+        .perform(
+            get("/api/cancer-types/nonexistent")
+                .accept(MediaType.APPLICATION_JSON)
+                .requestAttr("startTime", START_TIME))
+        .andExpect(status().isNotFound())
+        .andExpect(jsonPath("$.message").value("Cancer type not found: nonexistent"));
+  }
+
+  @Test
+  void getAllCancerTypes_withPagination_callsServiceWithCorrectParams() throws Exception {
+    List<TypeOfCancer> types = Arrays.asList(createCancerType("acc", "ACC"));
+
+    when(cancerTypeService.getAllCancerTypes(eq("SUMMARY"), eq(10), eq(2), any(), any()))
+        .thenReturn(types);
+
+    mockMvc
+        .perform(
+            get("/api/cancer-types")
+                .param("pageSize", "10")
+                .param("pageNumber", "2")
+                .accept(MediaType.APPLICATION_JSON)
+                .requestAttr("startTime", START_TIME))
+        .andExpect(status().isOk())
+        .andExpect(jsonPath("$.length()").value(1));
+  }
+
+  @Test
+  void getAllCancerTypes_withDetailedProjection_returnsOk() throws Exception {
+    List<TypeOfCancer> types = Arrays.asList(createCancerType("acc", "Adrenocortical Carcinoma"));
+
+    when(cancerTypeService.getAllCancerTypes(eq("DETAILED"), anyInt(), anyInt(), any(), any()))
+        .thenReturn(types);
+
+    mockMvc
+        .perform(
+            get("/api/cancer-types")
+                .param("projection", "DETAILED")
+                .accept(MediaType.APPLICATION_JSON)
+                .requestAttr("startTime", START_TIME))
+        .andExpect(status().isOk())
+        .andExpect(jsonPath("$.length()").value(1));
+  }
+
+  @Test
+  void getAllCancerTypes_emptyList_returnsEmptyArray() throws Exception {
+    when(cancerTypeService.getAllCancerTypes(any(), anyInt(), anyInt(), any(), any()))
+        .thenReturn(List.of());
+
+    mockMvc
+        .perform(
+            get("/api/cancer-types")
+                .accept(MediaType.APPLICATION_JSON)
+                .requestAttr("startTime", START_TIME))
+        .andExpect(status().isOk())
+        .andExpect(jsonPath("$.length()").value(0));
+  }
+}
