+
+    // ------------------------------------------------------------------
+    // GET /usertasks/instance/{taskId}/transition  – list available transitions
+    // ------------------------------------------------------------------
+
+    @Test
+    void listTransitions_happyPath() {
+        String taskId = getFirstTaskId();
+
+        // After activation the task is auto-claimed by user "manager" (the sole potentialUser).
+        // Status becomes RESERVED; checkPermission() only passes for the actual owner or admin.
+        given()
+                .accept(ContentType.JSON)
+                .queryParam("user", "manager")
+                .when()
+                .get(UT_BASE + "/" + taskId + "/transition")
+                .then()
+                .statusCode(200)
+                .body("$", not(empty()));
