+@DirtiesContext(classMode = DirtiesContext.ClassMode.AFTER_EACH_TEST_METHOD)
+class UserTasksRestTest {
+
+    private static final String UT_BASE = "/usertasks/instance";
+    private static final String APPROVALS_BASE = "/approvals";
+    private static final String NONEXISTENT = "00000000-0000-0000-0000-000000000000";
+    private static final String TEST_USER = "john";
+    private static final String TEST_GROUP = "managers";
+    private static final String TRAVELLER_JSON =
+            "{\"firstName\":\"Alice\",\"lastName\":\"Smith\",\"email\":\"alice@example.com\",\"nationality\":\"British\"}";
+    private static final String APPROVAL_INPUT =
+            "{\"approver\":\"" + TEST_USER + "\",\"traveller\":" + TRAVELLER_JSON + "}";
+
+    @LocalServerPort
+    private int port;
+
+    @BeforeEach
+    void setup() {
+        RestAssured.port = port;
+    }
+
+    // ------------------------------------------------------------------
+    // GET /usertasks/instance  – list tasks visible to user/group
+    // ------------------------------------------------------------------
+
+    @Test
+    void listUserTasks_noInstances_returnsEmptyList() {
+        given()
+                .accept(ContentType.JSON)
+                .queryParam("user", TEST_USER)
