+package org.kie.kogito.integrationtests.springboot;
+
+import org.junit.jupiter.api.BeforeEach;
+import org.junit.jupiter.api.Test;
+import org.springframework.boot.test.context.SpringBootTest;
+import org.springframework.boot.test.web.server.LocalServerPort;
+import org.springframework.test.annotation.DirtiesContext;
+
+import io.restassured.RestAssured;
+import io.restassured.http.ContentType;
+
+import static io.restassured.RestAssured.given;
+import static org.hamcrest.CoreMatchers.notNullValue;
+import static org.hamcrest.Matchers.empty;
+import static org.hamcrest.Matchers.hasSize;
+import static org.hamcrest.Matchers.not;
+
+@SpringBootTest(classes = KogitoSpringbootApplication.class,
+        webEnvironment = SpringBootTest.WebEnvironment.RANDOM_PORT)
+@DirtiesContext(classMode = DirtiesContext.ClassMode.AFTER_EACH_TEST_METHOD)
+class ApprovalsProcessRestTest {
+
+    private static final String BASE = "/approvals";
+    private static final String NONEXISTENT = "00000000-0000-0000-0000-000000000000";
+    private static final String TRAVELLER_JSON =
+            "{\"firstName\":\"Jane\",\"lastName\":\"Doe\",\"email\":\"jane@example.com\",\"nationality\":\"American\"}";
+    private static final String APPROVAL_INPUT =
+            "{\"approver\":\"admin\",\"traveller\":" + TRAVELLER_JSON + "}";
+
+    @LocalServerPort
+    private int port;
+
+    @BeforeEach
+    void setup() {
+        RestAssured.port = port;
+    }
+
+    // ------------------------------------------------------------------
+    // POST /approvals  – create a new process instance
+    // ------------------------------------------------------------------
+
+    @Test
+    void createInstance_withFullInput_returns201() {
+        given()
+                .contentType(ContentType.JSON)
+                .body(APPROVAL_INPUT)
+                .when()
+                .post(BASE)
+                .then()
+                .statusCode(201)
+                .header("Location", notNullValue())
+                .body("id", notNullValue());
+    }
+
+    @Test
+    void createInstance_withEmptyInput_returns201() {
+        given()
+                .contentType(ContentType.JSON)
+                .body("{}")
+                .when()
+                .post(BASE)
+                .then()
+                .statusCode(201)
+                .body("id", notNullValue());
+    }
+
+    @Test
+    void createInstance_withBusinessKey_returns201AndLocationContainsId() {
+        String location = given()
+                .contentType(ContentType.JSON)
+                .body(APPROVAL_INPUT)
+                .queryParam("businessKey", "BK-001")
+                .when()
+                .post(BASE)
+                .then()
+                .statusCode(201)
+                .header("Location", notNullValue())
+                .extract().header("Location");
+
+        // The Location header should point to the created resource
+        String id = given()
+                .contentType(ContentType.JSON)
+                .body(APPROVAL_INPUT)
+                .when()
+                .post(BASE)
+                .then()
+                .statusCode(201)
+                .extract().path("id");
+
+        // Just verify location is a non-empty string (base URL + path)
+        assert location != null && !location.isEmpty();
+    }
+
+    // ------------------------------------------------------------------
+    // GET /approvals  – list all active instances
+    // ------------------------------------------------------------------
+
+    @Test
+    void listInstances_empty() {
+        given()
+                .accept(ContentType.JSON)
+                .when()
+                .get(BASE)
+                .then()
+                .statusCode(200)
+                .body("$", empty());
+    }
+
+    @Test
+    void listInstances_afterCreation_containsInstance() {
+        String id = createApprovalInstance();
+
+        given()
+                .accept(ContentType.JSON)
+                .when()
+                .get(BASE)
+                .then()
+                .statusCode(200)
+                .body("$", not(empty()))
+                .body("[0].id", notNullValue());
+    }
+
+    @Test
+    void listInstances_multipleConcurrentInstances() {
+        createApprovalInstance();
+        createApprovalInstance();
+
+        given()
+                .accept(ContentType.JSON)
+                .when()
+                .get(BASE)
+                .then()
+                .statusCode(200)
+                .body("$", hasSize(2));
+    }
+
+    // ------------------------------------------------------------------
+    // GET /approvals/schema  – JSON schema for the process input model
+    // ------------------------------------------------------------------
+
+    @Test
+    void getSchema_returnsJsonObject() {
+        given()
+                .accept(ContentType.JSON)
+                .when()
+                .get(BASE + "/schema")
+                .then()
+                .statusCode(200);
+    }
+
+    // ------------------------------------------------------------------
+    // GET /approvals/{id}  – get a single process instance
+    // ------------------------------------------------------------------
+
+    @Test
+    void getInstance_happyPath() {
+        String id = createApprovalInstance();
+
+        given()
+                .accept(ContentType.JSON)
+                .when()
+                .get(BASE + "/" + id)
+                .then()
+                .statusCode(200);
+    }
+
+    @Test
+    void getInstance_notFound() {
+        given()
+                .accept(ContentType.JSON)
+                .when()
+                .get(BASE + "/" + NONEXISTENT)
+                .then()
+                .statusCode(404);
+    }
+
+    // ------------------------------------------------------------------
+    // DELETE /approvals/{id}  – abort a process instance
+    // ------------------------------------------------------------------
+
+    @Test
+    void deleteInstance_happyPath() {
+        String id = createApprovalInstance();
+
+        given()
+                .accept(ContentType.JSON)
+                .when()
+                .delete(BASE + "/" + id)
+                .then()
+                .statusCode(200);
+
+        // Confirm gone
+        given()
+                .accept(ContentType.JSON)
+                .when()
+                .get(BASE + "/" + id)
+                .then()
+                .statusCode(404);
+    }
+
+    @Test
+    void deleteInstance_notFound() {
+        given()
+                .accept(ContentType.JSON)
+                .when()
+                .delete(BASE + "/" + NONEXISTENT)
+                .then()
+                .statusCode(404);
+    }
+
+    // ------------------------------------------------------------------
+    // PUT /approvals/{id}  – full model update
+    // ------------------------------------------------------------------
+
+    @Test
+    void updateInstance_happyPath() {
+        String id = createApprovalInstance();
+
+        given()
+                .contentType(ContentType.JSON)
+                .body("{\"approver\":\"alice\"}")
+                .when()
+                .put(BASE + "/" + id)
+                .then()
+                .statusCode(200);
+    }
+
+    @Test
+    void updateInstance_notFound() {
+        given()
+                .contentType(ContentType.JSON)
+                .body("{\"approver\":\"alice\"}")
+                .when()
+                .put(BASE + "/" + NONEXISTENT)
+                .then()
+                .statusCode(404);
+    }
+
+    // ------------------------------------------------------------------
+    // PATCH /approvals/{id}  – partial model update
+    // ------------------------------------------------------------------
+
+    @Test
+    void patchInstance_happyPath() {
+        String id = createApprovalInstance();
+
+        given()
+                .contentType(ContentType.JSON)
+                .body("{\"approver\":\"bob\"}")
+                .when()
+                .patch(BASE + "/" + id)
+                .then()
+                .statusCode(200);
+    }
+
+    @Test
+    void patchInstance_notFound() {
+        given()
+                .contentType(ContentType.JSON)
+                .body("{\"approver\":\"bob\"}")
+                .when()
+                .patch(BASE + "/" + NONEXISTENT)
+                .then()
+                .statusCode(404);
+    }
+
+    // ------------------------------------------------------------------
+    // GET /approvals/{id}/tasks  – list work items / active tasks
+    // ------------------------------------------------------------------
+
+    @Test
+    void getTasks_happyPath() {
+        String id = createApprovalInstance();
+
+        // Without user/group the identity is null and the task is filtered out of results.
+        // Pass the potentialUser "manager" to get a non-empty list.
+        given()
+                .accept(ContentType.JSON)
+                .queryParam("user", "manager")
+                .queryParam("group", "managers")
+                .when()
+                .get(BASE + "/" + id + "/tasks")
+                .then()
+                .statusCode(200)
+                .body("$", not(empty()));
+    }
+
+    @Test
+    void getTasks_notFound() {
+        given()
+                .accept(ContentType.JSON)
+                .when()
+                .get(BASE + "/" + NONEXISTENT + "/tasks")
+                .then()
+                .statusCode(404);
+    }
+
+    @Test
+    void getTasks_withUserAndGroup() {
+        String id = createApprovalInstance();
+
+        given()
+                .accept(ContentType.JSON)
+                .queryParam("user", "john")
+                .queryParam("group", "managers")
+                .when()
+                .get(BASE + "/" + id + "/tasks")
+                .then()
+                .statusCode(200);
+    }
+
+    // ------------------------------------------------------------------
+    // Helpers
+    // ------------------------------------------------------------------
+
+    private String createApprovalInstance() {
+        return given()
+                .contentType(ContentType.JSON)
+                .body(APPROVAL_INPUT)
+                .when()
+                .post(BASE)
+                .then()
+                .statusCode(201)
+                .extract().path("id");
+    }
+}
