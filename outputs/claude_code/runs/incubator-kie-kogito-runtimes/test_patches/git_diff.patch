+                .queryParam("group", TEST_GROUP)
+                .when()
+                .get(UT_BASE)
+                .then()
+                .statusCode(200)
+                .body("$", not(empty()))
+                .body("[0].id", notNullValue());
+    }
+
+    // ------------------------------------------------------------------
+    // GET /usertasks/instance/{taskId}  – get single user task
+    // ------------------------------------------------------------------
+
+    @Test
+    void getUserTask_happyPath() {
+        String taskId = getFirstTaskId();
+
+        given()
+                .accept(ContentType.JSON)
+                .queryParam("user", TEST_USER)
+                .queryParam("group", TEST_GROUP)
+                .when()
+                .get(UT_BASE + "/" + taskId)
+                .then()
+                .statusCode(200)
+                .body("id", notNullValue());
+    }
+
+    @Test
+    void getUserTask_notFound() {
+        given()
+                .accept(ContentType.JSON)
+                .queryParam("user", TEST_USER)
+                .queryParam("group", TEST_GROUP)
+                .when()
+                .get(UT_BASE + "/" + NONEXISTENT)
