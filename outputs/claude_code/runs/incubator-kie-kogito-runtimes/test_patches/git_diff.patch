+
+    @Test
+    void getVersion_returnsVersionJson() {
+        given()
+                .accept(ContentType.JSON)
+                .when()
+                .get("/version")
+                .then()
+                .statusCode(200)
+                .body("version", notNullValue());
+    }
+
+    @Test
+    void getVersion_versionIsString() {
+        String version = given()
+                .accept(ContentType.JSON)
+                .when()
+                .get("/version")
+                .then()
+                .statusCode(200)
+                .extract().path("version");
+
+        // Version should be a non-empty string (e.g. "1.0" or "999-SNAPSHOT")
+        assert version != null && !version.isEmpty();
+    }
