+package org.kie.kogito.integrationtests.springboot;
+
+import java.util.List;
+import java.util.Map;
+
+import org.junit.jupiter.api.BeforeEach;
+import org.junit.jupiter.api.Test;
+import org.springframework.boot.test.context.SpringBootTest;
+import org.springframework.boot.test.web.server.LocalServerPort;
+import org.springframework.test.annotation.DirtiesContext;
+
+import io.restassured.RestAssured;
+import io.restassured.http.ContentType;
+
+import static io.restassured.RestAssured.given;
+
+/**
+ * Tests for TaskManagementRestController at /management/usertasks/*.
+ * A running approvals process instance is created first so that a real task ID can be obtained.
+ */
+@SpringBootTest(classes = KogitoSpringbootApplication.class,
+        webEnvironment = SpringBootTest.WebEnvironment.RANDOM_PORT)
+@DirtiesContext(classMode = DirtiesContext.ClassMode.AFTER_EACH_TEST_METHOD)
+class TaskManagementRestTest {
+
+    private static final String TASK_MGMT_BASE = "/management/usertasks";
+    private static final String APPROVALS_BASE = "/approvals";
+    private static final String UT_BASE = "/usertasks/instance";
+    private static final String TEST_USER = "john";
+    private static final String TEST_GROUP = "managers";
+    // enforceAdminOrOwner() in the compiled TaskManagementService (March 31 JAR) only allows
+    // users in adminUsers/adminGroups or the WORKFLOW_ENGINE_USER bypass identity.
+    // The approval task has empty adminUsers/adminGroups, so only WORKFLOW_ENGINE_USER passes.
+    private static final String ADMIN_USER = "WORKFLOW_ENGINE_USER";
+    private static final String TRAVELLER_JSON =
+            "{\"firstName\":\"Bob\",\"lastName\":\"Builder\",\"email\":\"bob@example.com\",\"nationality\":\"Canadian\"}";
+    private static final String APPROVAL_INPUT =
+            "{\"approver\":\"" + TEST_USER + "\",\"traveller\":" + TRAVELLER_JSON + "}";
+
+    @LocalServerPort
+    private int port;
+
+    @BeforeEach
+    void setup() {
+        RestAssured.port = port;
+    }
+
+    // ------------------------------------------------------------------
+    // GET /management/usertasks/{taskId}
+    // ------------------------------------------------------------------
+
+    @Test
+    void getTask_happyPath() {
+        String taskId = getFirstUserTaskId();
+
+        given()
+                .accept(ContentType.JSON)
+                .queryParam("user", TEST_USER)
+                .queryParam("group", TEST_GROUP)
+                .when()
+                .get(TASK_MGMT_BASE + "/" + taskId)
+                .then()
+                .statusCode(200);
+    }
+
+    // ------------------------------------------------------------------
+    // PUT /management/usertasks/{taskId}  – full update
+    // ------------------------------------------------------------------
+
+    @Test
+    void putTask_fullUpdate_returns200() {
+        String taskId = getFirstUserTaskId();
+
+        String body = "{"
+                + "\"description\":\"Updated via PUT\","
+                + "\"priority\":\"High\","
+                + "\"potentialUsers\":[\"alice\",\"bob\"],"
+                + "\"potentialGroups\":[\"managers\"],"
+                + "\"excludedUsers\":[],"
+                + "\"adminUsers\":[\"admin\"],"
+                + "\"adminGroups\":[\"admins\"],"
+                + "\"inputParams\":{}"
+                + "}";
+
+        given()
+                .contentType(ContentType.JSON)
+                .queryParam("user", ADMIN_USER)
+                .body(body)
+                .when()
+                .put(TASK_MGMT_BASE + "/" + taskId)
+                .then()
+                .statusCode(200);
+    }
+
+    @Test
+    void putTask_updatesDescription() {
+        String taskId = getFirstUserTaskId();
+
+        String body = "{"
+                + "\"description\":\"New description\","
+                + "\"priority\":\"Medium\","
+                + "\"potentialUsers\":[],"
+                + "\"potentialGroups\":[],"
+                + "\"excludedUsers\":[],"
+                + "\"adminUsers\":[],"
+                + "\"adminGroups\":[],"
+                + "\"inputParams\":{}"
+                + "}";
+
+        given()
+                .contentType(ContentType.JSON)
+                .queryParam("user", ADMIN_USER)
+                .body(body)
+                .when()
+                .put(TASK_MGMT_BASE + "/" + taskId)
+                .then()
+                .statusCode(200);
+
+        // Verify the update persisted via GET
+        given()
+                .accept(ContentType.JSON)
+                .queryParam("user", TEST_USER)
+                .queryParam("group", TEST_GROUP)
+                .when()
+                .get(TASK_MGMT_BASE + "/" + taskId)
+                .then()
+                .statusCode(200);
+    }
+
+    // ------------------------------------------------------------------
+    // PATCH /management/usertasks/{taskId}  – partial update
+    // ------------------------------------------------------------------
+
+    @Test
+    void patchTask_partialUpdate_returnsUpdatedTaskInfo() {
+        String taskId = getFirstUserTaskId();
+
+        String body = "{"
+                + "\"description\":\"Patched description\","
+                + "\"priority\":\"Low\""
+                + "}";
+
+        given()
+                .contentType(ContentType.JSON)
+                .queryParam("user", ADMIN_USER)
+                .body(body)
+                .when()
+                .patch(TASK_MGMT_BASE + "/" + taskId)
+                .then()
+                .statusCode(200);
+    }
+
+    @Test
+    void patchTask_onlyPriority() {
+        String taskId = getFirstUserTaskId();
+
+        given()
+                .contentType(ContentType.JSON)
+                .queryParam("user", ADMIN_USER)
+                .body("{\"priority\":\"High\"}")
+                .when()
+                .patch(TASK_MGMT_BASE + "/" + taskId)
+                .then()
+                .statusCode(200);
+    }
+
+    // ------------------------------------------------------------------
+    // Helpers
+    // ------------------------------------------------------------------
+
+    private String getFirstUserTaskId() {
+        // Start a new approvals process instance which will create a user task
+        given()
+                .contentType(ContentType.JSON)
+                .body(APPROVAL_INPUT)
+                .when()
+                .post(APPROVALS_BASE)
+                .then()
+                .statusCode(201);
+
+        List<Map<String, Object>> tasks = given()
+                .accept(ContentType.JSON)
+                .queryParam("user", TEST_USER)
+                .queryParam("group", TEST_GROUP)
+                .when()
+                .get(UT_BASE)
+                .then()
+                .statusCode(200)
+                .extract().jsonPath().getList("$");
+
+        if (tasks == null || tasks.isEmpty()) {
+            throw new IllegalStateException("No user tasks found after starting approval process");
+        }
+        return (String) tasks.get(0).get("id");
+    }
+}
